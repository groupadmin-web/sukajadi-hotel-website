---
import homepageData from "@/content/homepage.json";

// We force the exact absolute path or fallback to the standard public logo asset directory
const logoImage = homepageData.logo_image || "/images/logo.png"; 
const brandName = homepageData.logo_text || "Mutiara";
---

<footer class="w-full bg-slate-950 text-slate-400 font-sans border-t border-slate-900 pt-16 pb-8 relative overflow-hidden left-0 right-0">
  
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-amber-500/5 rounded-full blur-3xl pointer-events-none select-none"></div>

  {/* INTERNAL INNER GRID INNER SHIELD */}
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-12 border-b border-slate-900">
    
    {/* COLUMN 1: THE REAL VERIFIED NAVBAR BRAND LOGO IMAGE */}
    <div class="flex flex-col gap-4">
      <div class="flex flex-col items-start gap-2">
        
        {/* We output BOTH the image and fallback option explicitly so it never renders blank */}
        <div class="flex items-center gap-3">
          <img 
            src="/images/logo.png" 
            alt="Mutiara Logo" 
            class="h-10 w-auto object-contain"
            onerror="this.style.display='none'" 
          />
          <span 
            class="text-white text-3xl tracking-wide" 
            style="font-family: 'EB Garamond', Georgia, serif !important;"
          >
            {brandName}
          </span>
        </div>
        
        {/* BRAND SUBTITLE */}
        <span class="text-[10px] text-amber-500 tracking-[0.25em] font-bold uppercase mt-2">
          Hotel & Convention
        </span>
      </div>
      <p class="text-xs leading-relaxed text-slate-500 max-w-xs mt-2">
        Providing an impeccable blend of luxury hospitality and high-performance corporate event execution in the heart of Bandung City.
      </p>
    </div>

    {/* COLUMN 2: ACCOMMODATION ANCHORS */}
    <div>
      <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-l-2 border-amber-500 pl-2.5">
        Accommodations
      </h4>
      <ul class="flex flex-col gap-3 text-xs">
        <li><a href="#rooms" class="hover:text-amber-500 transition-colors duration-300">Executive Deluxe Rooms</a></li>
        <li><a href="#rooms" class="hover:text-amber-500 transition-colors duration-300">Business Premier Suites</a></li>
        <li><a href="#rooms" class="hover:text-amber-500 transition-colors duration-300">Grand Family Sanctuaries</a></li>
        <li><a href="https://m.mutiarahotel.com" target="_blank" rel="noopener noreferrer" class="text-amber-400 font-medium hover:underline">Direct Reservation Portal →</a></li>
      </ul>
    </div>

    {/* COLUMN 3: MICE / CONVENTION ASSETS */}
    <div>
      <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-l-2 border-amber-500 pl-2.5">
        Events & Conventions
      </h4>
      <ul class="flex flex-col gap-3 text-xs">
        <li><a href="#events" class="hover:text-amber-500 transition-colors duration-300">Grand Ballroom</a></li>
        <li><a href="#events" class="hover:text-amber-500 transition-colors duration-300">Corporate Boardrooms</a></li>
        <li><a href="#events" class="hover:text-amber-500 transition-colors duration-300">MICE Infrastructure</a></li>
      </ul>
    </div>

    {/* COLUMN 4: LOCAL CONCIERGE ACCESS COORD */}
    <div>
      <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-l-2 border-amber-500 pl-2.5">
        The Concierge Desk
      </h4>
      <div class="flex flex-col gap-3 text-xs leading-relaxed text-slate-400">
        <p class="flex gap-2">
          <span class="text-amber-500">📍</span>
          <span>Jalan Kebon Kawung No. 60,<br />Bandung, West Java, Indonesia</span>
        </p>
        <p class="flex gap-2 mt-1">
          <span class="text-amber-500">📞</span>
          <a href="tel:+62224200888" class="hover:text-white transition-colors">+62 (022) 420 0888</a>
        </p>
      </div>
    </div>

  </div>

  {/* BOTTOM CORE CREDIT DESK BAR */}
  <div class="max-w-7xl mx-auto px-6 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] text-slate-600 font-medium">
    <p>
      &copy; {new Date().getFullYear()} Mutiara Hotel & Convention Bandung. All Rights Reserved.
    </p>
    <div class="flex gap-6">
      <a href="#privacy" class="hover:text-slate-400 transition-colors">Privacy Charter</a>
      <span class="text-slate-800">|</span>
      <p>Designed with Luxury Standards</p>
    </div>
  </div>

</footer>
