---
// src/components/footer.astro
import homepageData from "../content/homepage.json";

// Safely pull the brand logo asset
const logoImage = homepageData?.logo_image;

// FAIL-SAFE DATA FALLBACKS
let footer = {
  footer_slogan: "Providing an impeccable blend of luxury hospitality and high-performance corporate event execution in the heart of Bandung City.",
  concierge_address: "Jalan Kebon Kawung No. 60, Bandung, West Java, Indonesia",
  concierge_phone: "+62 (022) 420 0888",
  concierge_phone_raw: "+62224200888",
  concierge_email: "info@mutiarahotel.com",
  instagram_url: "#",
  facebook_url: "#",
  youtube_url: "https://www.youtube.com/@hotelmutiarabandung",
  privacy_content: "1. Direct Booking Security\n\nMutiara Hotel & Convention Bandung ensures that your reservation data transmitted via our direct channels is fully encrypted.\n\n2. Information Collected\n\nWe process full guest names, identifiers, and coordinate paths required under Indonesian law."
};

try {
  const cmsData = await import("../content/footer.json");
  if (cmsData && cmsData.default) {
    footer = cmsData.default;
  }
} catch (e) {}
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<footer id="footer" class="w-full bg-slate-950 text-slate-400 font-sans border-t border-slate-900 py-8 relative overflow-hidden left-0 right-0" style="padding-top: 2rem !important; padding-bottom: 1.5rem !important;">
  
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-amber-500/5 rounded-full blur-3xl pointer-events-none select-none"></div>

  {/* THREE COLUMN GRID */}
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6 pb-5 border-b border-slate-900 text-left">
    
    {/* COLUMN 1: BRAND LOGO BLOCKS & SLOGAN */}
    <div class="flex flex-col gap-2 md:col-span-1">
      <div class="flex flex-row items-center gap-3">
        {logoImage && (
          <img 
            src={logoImage} 
            alt="Mutiara Brand Logo" 
            class="h-11 w-auto object-contain brightness-110 flex-shrink-0"
            onerror="this.style.display='none';"
          />
        )}
        <div class="flex flex-col justify-center select-none">
          <span 
            class="text-white text-xl font-medium uppercase leading-none block" 
            style="font-family: 'EB Garamond', Georgia, serif !important; letter-spacing: 4px;"
          >
            Mutiara
          </span>
          <span class="text-[9px] text-amber-500 font-bold uppercase mt-1.5 block tracking-[0.14em]">
            Hotel & Convention
          </span>
        </div>
      </div>
      <p class="text-[11px] leading-relaxed text-slate-500 max-w-sm">
        {footer.footer_slogan}
      </p>
    </div>

    {/* COLUMN 2: GEOGRAPHIC & CONTACT COORDINATES */}
    <div>
      <h4 class="text-white text-[11px] font-bold uppercase tracking-widest mb-2.5 border-l-2 border-amber-500 pl-2">
        The Concierge Desk
      </h4>
      <div class="flex flex-col gap-1.5 text-[11px] leading-relaxed text-slate-400">
        
        {/* INTERACTIVE NATIVE TRIGGER */}
        <button id="open-map" class="flex gap-2 text-left group cursor-pointer hover:text-white transition-colors w-full focus:outline-none">
          <span class="text-amber-500 shrink-0 group-hover:scale-110 transition-transform">📍</span>
          <span class="underline decoration-slate-800 underline-offset-4 group-hover:decoration-amber-500 transition-colors">{footer.concierge_address}</span>
        </button>

        <p class="flex items-center gap-2 mt-0.5">
          <span class="text-amber-500 shrink-0 select-none">📞</span>
          <a href={`tel:${footer.concierge_phone_raw}`} class="hover:text-white transition-colors">
            {footer.concierge_phone}
          </a>
        </p>
        
        {footer.concierge_email && (
          {/* Update this exact block inside src/components/footer.astro */}
          <p class="flex items-center gap-2">
            <span class="text-amber-500 shrink-0 w-3.5 h-3.5 flex items-center justify-center pointer-events-none select-none">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </span>
            
            {/* FIXED TRACKER HOOK */}
            <a 
              id="secure-footer-email"
              href={`mailto:${footer.concierge_email}`} 
              class="hover:text-white transition-colors cursor-pointer notranslate"
              data-sec-u="info"
              data-sec-d="mutiarahotel.com"
            >
              {footer.concierge_email}
            </a>
          </p>
        )}
      </div>
    </div>

    {/* COLUMN 3: CONNECTIVITY */}
    <div>
      <h4 class="text-white text-[11px] font-bold uppercase tracking-widest mb-2.5 border-l-2 border-amber-500 pl-2">
        Follow Our Journey
      </h4>
      <p
