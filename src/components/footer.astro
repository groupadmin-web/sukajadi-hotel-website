---
// src/components/footer.astro
import homepageData from "../content/homepage.json";

// Safely pull the brand logo asset
const logoImage = homepageData?.logo_image;

// FAIL-SAFE DATA FALLBACKS
let footer = {
  footer_slogan: "Providing an impeccable blend of luxury hospitality and high-performance corporate event execution in the heart of Bandung City.",
  concierge_address: "Jalan Kebon Kawung No. 60, Bandung, West Java, Indonesia",
  concierge_phone: "+62 (022) 420 0888",
  concierge_phone_raw: "+62224200888",
  concierge_email: "info@mutiarahotel.com",
  instagram_url: "#",
  facebook_url: "#",
  youtube_url: "https://www.youtube.com/@hotelmutiarabandung" // UPDATED: Core channel pointer
};

try {
  const cmsData = await import("../content/footer.json");
  if (cmsData && cmsData.default) {
    footer = cmsData.default;
  }
} catch (e) {}
---

{/* MODERATE COMPRESSION: Hardcoded inline clamp layout override style to force a 1/3 height reduction */}
<footer id="footer" class="w-full bg-slate-950 text-slate-400 font-sans border-t border-slate-900 py-8 relative overflow-hidden left-0 right-0" style="padding-top: 2rem !important; padding-bottom: 1.5rem !important;">
  
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-amber-500/5 rounded-full blur-3xl pointer-events-none select-none"></div>

  {/* THREE COLUMN GRID - Compact gaps */}
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6 pb-5 border-b border-slate-900 text-left">
    
    {/* COLUMN 1: BRAND LOGO BLOCKS & SLOGAN */}
    <div class="flex flex-col gap-2 md:col-span-1">
      <div class="flex flex-row items-center gap-3">
        {logoImage && (
          <img 
            src={logoImage} 
            alt="Mutiara Brand Logo" 
            class="h-10 w-auto object-contain brightness-110 flex-shrink-0"
            onerror="this.style.display='none';"
          />
        )}
        <div class="flex flex-col justify-center">
          <span 
            class="text-white text-lg font-medium uppercase leading-none select-none" 
            style="font-family: 'EB Garamond', Georgia, serif !important; letter-spacing: 3px !important; margin-right: -3px !important;"
          >
            Mutiara
          </span>
          <span class="text-[9px] text-amber-500 tracking-[0.12em] font-bold uppercase mt-1.5 whitespace-nowrap select-none">
            Hotel & Convention
          </span>
        </div>
      </div>
      <p class="text-[11px] leading-relaxed text-slate-500 max-w-sm">
        {footer.footer_slogan}
      </p>
    </div>

    {/* COLUMN 2: GEOGRAPHIC & CONTACT COORDINATES COMBINED */}
    <div>
      <h4 class="text-white text-[11px] font-bold uppercase tracking-widest mb-2.5 border-l-2 border-amber-500 pl-2">
        The Concierge Desk
      </h4>
      <div class="flex flex-col gap-1.5 text-[11px] leading-relaxed text-slate-400">
        <p class="flex gap-2">
          <span class="text-amber-500 shrink-0">📍</span>
          <span>{footer.concierge_address}</span>
        </p>
        <p class="flex gap-2">
          <span class="text-amber-500 shrink-0">📞</span>
          <a href={`tel:${footer.concierge_phone_raw}`} class="hover:text-white transition-colors">
            {footer.concierge_phone}
          </a>
        </p>
        {footer.concierge_email && (
          <p class="flex gap-2">
            <span class="text-amber-500 shrink-0">✉️</span>
            <a href={`mailto:${footer.concierge_email}`} class="hover:text-white transition-colors">
              {footer.concierge_email}
            </a>
          </p>
        )}
      </div>
    </div>

    {/* COLUMN 3: CONNECTIVITY WITH TEXT + LOGOS */}
    <div>
      <h4 class="text-white text-[11px] font-bold uppercase tracking-widest mb-2.5 border-l-2 border-amber-500 pl-2">
        Follow Our Journey
      </h4>
      <p class="text-[11px] text-slate-500 mb-2.5 max-w-xs leading-relaxed">
        Stay updated with our latest stay packages and venue offerings.
      </p>
      
      <div class="flex items-center gap-2 flex-wrap">
        {footer.instagram_url && (
          <a href={footer.instagram_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-2.5 py-1.5 rounded bg-slate-900 border border-slate-800 text-slate-400 hover:text-amber-500 hover:border-amber-500/30 transition-all duration-200 text-[10px] font-bold font-sans uppercase tracking-wider group" aria-label="Mutiara Instagram">
            <svg role="img" viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current"><path d="M12 0C8.74 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.74 0 12s.014 3.667.072 4.947c.2 4.358 2.618 6.78 6.977 6.98 1.281.058 1.689.072 4.948.072 3.251 0 3.66-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.251-.014-3.66-.073-4.948-.2-4.355-2.617-6.783-6.979-6.98C15.66.014 15.251 0 12 0zm0 5.838a6.162 6.162 0 1 1 0 12.324 6.162 6.162 0 0 1 0-12.324zM12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <span>Instagram</span>
          </a>
        )}
        
        {footer.facebook_url && (
          <a href={footer.facebook_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-2.5 py-1.5 rounded bg-slate-900 border border-slate-800 text-slate-400 hover:text-amber-500 hover:border-amber-500/30 transition-all duration-200 text-[10px] font-bold font-sans uppercase tracking-wider group" aria-label="Mutiara Facebook">
            <svg role="img" viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span>Facebook</span>
          </a>
        )}
        
        {footer.youtube_url && (
          <a href={footer.youtube_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-2.5 py-1.5 rounded bg-slate-900 border border-slate-800 text-slate-400 hover:text-amber-500 hover:border-amber-500/30 transition-all duration-200 text-[10px] font-bold font-sans uppercase tracking-wider group" aria-label="Mutiara YouTube">
            {/* FIXED: Repaired the broken token string in the vector coordinates layout frame */}
            <svg role="img" viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-current"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span>YouTube</span>
          </a>
        )}
      </div>
    </div>

  </div>

  {/* BOTTOM BASELINE COPYRIGHT STRIP */}
  <div class="max-w-7xl mx-auto px-6 pt-3 flex flex-col md:flex-row justify-between items-center gap-3 text-[10px] text-slate-600 font-medium">
    <p>
      &copy; {new Date().getFullYear()} Mutiara Hotel & Convention Bandung. All Rights Reserved.
    </p>
    <div class="flex gap-4">
      <a href="#privacy" class="hover:text-slate-400 transition-colors">Privacy Charter</a>
      <span class="text-slate-800">|</span>
      <p>Direct Booking Guarantee Enabled</p>
    </div>
  </div>

</footer>
