---
// FIXED AUTOMATED PLATFORM SCHEDULER
const trustedPartners = [
  {
    name: "Booking.com",
    label: "Verified Booking Channel",
    // Pulls directly from the official universal SVG asset repository
    logoUrl: "https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_Logo_Grey.svg"
  },
  {
    name: "Traveloka",
    label: "Preferred Local Partner",
    // Scaled flat logo asset file link
    logoUrl: "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/Traveloka_Logo.svg/320px-Traveloka_Logo.svg.png"
  },
  {
    name: "Agoda",
    label: "Global Preferred Choice",
    logoUrl: "https://upload.wikimedia.org/wikipedia/commons/0/0b/Agoda_logo.svg"
  },
  {
    name: "Google Travel",
    label: "Top Guest Rating Stream",
    logoUrl: "https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_Travel_Icon.svg"
  }
];
---

<div class="mt-20 mb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 font-sans">
  
  <p class="text-center text-[10px] sm:text-xs font-semibold tracking-[0.25em] text-slate-400 uppercase mb-10">
    Official Reservation Channels & Verification Partners
  </p>
  
  <div class="grid grid-cols-2 md:grid-cols-4 items-center justify-center gap-8 md:gap-12 lg:gap-16">
    {
      trustedPartners.map((partner) => (
        <div class="flex flex-col items-center justify-center text-center group transition-all duration-300">
          
          {/* SECURE AUTO-LOADING IMAGE CONTAINER */}
          <div class="h-10 w-full max-w-[130px] flex items-center justify-center mb-2">
            <img 
              src={partner.logoUrl} 
              alt={`${partner.name} Network Branding`} 
              class="max-h-full max-w-full object-contain filter grayscale opacity-35 group-hover:grayscale-0 group-hover:opacity-90 transition-all duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <span class="text-[10px] font-medium tracking-wide text-slate-400/70 group-hover:text-amber-600 transition-colors duration-300">
            {partner.label}
          </span>
          
        </div>
      ))
    }
  </div>
  
  <div class="h-[1px] w-full bg-gradient-to-r from-transparent via-slate-200/50 to-transparent mt-16"></div>
</div>
