---
import homepageData from "@/content/homepage.json";
import badgesData from "@/content/badges.json";

// Read the master toggle switch from Section 1 (Defaults to true if missing)
const showPartnersRow = homepageData.show_partners !== false;
const safeBadges = badgesData || [];

const officialLogos = {
  traveloka: "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/Traveloka_Logo.svg/320px-Traveloka_Logo.svg.png",
  agoda: "https://logos-world.net/wp-content/uploads/2023/02/Agoda-Logo-700x394.png"
};
---

{/* CONDITIONAL RENDER CHECK CONTAINER */}
{showPartnersRow && (
  <div class="mt-24 mb-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 font-sans animate-fade-in">
    
    <p class="text-center text-xs font-bold tracking-[0.25em] text-slate-500 uppercase mb-12">
      Official Reservation Channels & Verification Partners
    </p>
    
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-7 items-center justify-center gap-8 md:gap-12 lg:gap-14">
      {
        safeBadges.map((badge) => {
          const staffTypedName = (badge.name || "").toLowerCase().trim();
          
          return (
            <div class="flex flex-col items-center justify-center text-center group transition-all duration-300 transform hover:-translate-y-0.5">
              
              <div class="h-12 w-full max-w-[140px] flex items-center justify-center mb-3">
                
                {/* BOOKING.COM MATCH */}
                {staffTypedName.includes("booking") && (
                  <div class="flex items-center justify-center bg-[#003580] text-white px-3 py-1 rounded font-sans font-bold tracking-tight text-sm select-none group-hover:bg-[#00224f] transition-colors">
                    Booking.com
                  </div>
                )}

                {/* TRAVELOKA MATCH */}
                {staffTypedName.includes("traveloka") && (
                  <img 
                    src={officialLogos.traveloka} 
                    alt="Traveloka" 
                    class="max-h-5 max-w-full object-contain filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                    loading="lazy"
                  />
                )}

                {/* BRAND-ACCURATE AGODA MATCH */}
                {staffTypedName.includes("agoda") && (
                  <div class="flex flex-col items-center select-none scale-95 filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500">
                    <span class="text-2xl font-normal tracking-tight font-sans text-slate-700 leading-none lowercase">
                      agoda
                    </span>
                    <div class="flex gap-1 mt-1.5 justify-center">
                      <span class="w-2 h-2 rounded-full bg-[#f43f5e]"></span>
                      <span class="w-2 h-2 rounded-full bg-[#eab308]"></span>
                      <span class="w-2 h-2 rounded-full bg-[#10b981]"></span>
                      <span class="w-2 h-2 rounded-full bg-[#a855f7]"></span>
                      <span class="w-2 h-2 rounded-full bg-[#0ea5e9]"></span>
                    </div>
                  </div>
                )}

                {/* AUTHENTIC MULTI-COLOR GOOGLE LOGOMARK */}
                {staffTypedName.includes("google") && (
                  <div class="w-full flex items-center justify-center filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 select-none">
                    <svg class="h-5 w-auto" viewBox="0 0 272 92" xmlns="http://www.w3.org/2000/svg">
                      <path d="M44.5 20c-7.2 0-14.3 2.7-19.4 8.1s-7.8 12.8-7.8 21.9c0 9 2.7 16.3 8 21.6s12.3 8 19.5 8c6 0 11.2-1.5 15.4-4.4V60.9H44.1v-12h27.9v35.1C65.5 89 56.4 92 44.5 92 31.1 92 20.3 87.5 12.2 78.6S0 59.3 0 46.2C0 33.1 4.1 21.9 12.3 13.1S31.2 0 44.5 0c11.3 0 20.6 3.1 27.8 9.4l-8.7 8.8c-5-4.4-11.2-8.2-19.1-8.2z" fill="#4285F4"/>
                      <path d="M101.4 31.4c8.4 0 15.3 3.1 20.7 9.2s8.1 14 8.1 23.6-2.7 17.5-8.1 23.6-12.3 9.2-20.7 9.2c-8.5 0-15.4-3.1-20.8-9.2s-8.1-14-8.1-23.6 2.7-17.5 8.1-23.6 12.3-9.2 20.8-9.2zm0 11.5c-4.9 0-8.9 1.9-11.9 5.8s-4.5 9.1-4.5 15.5 1.5 11.6 4.5 15.5 7 5.8 11.9 5.8c5 0 9-1.9 12-5.8s4.5-9.1 4.5-15.5-1.5-11.6-4.5-15.5-7-5.8-12-5.8z" fill="#EA4335"/>
                      <path d="M167.3 31.4c8.4 0 15.3 3.1 20.7 9.2s8.1 14 8.1 23.6-2.7 17.5-8.1 23.6-12.3 9.2-20.7 9.2c-8.5 0-15.4-3.1-20.8-9.2s-8.1-14-8.1-23.6 2.7-17.5 8.1-23.6 12.3-9.2 20.8-9.2zm0 11.5c-4.9 0-8.9 1.9-11.9 5.8s-4.5 9.1-4.5 15.5 1.5 11.6 4.5 15.5 7 5.8 11.9 5.8c5 0 9-1.9 12-5.8s4.5-9.1 4.5-15.5-1.5-11.6-4.5-15.5-7-5.8-12-5.8z" fill="#FBBC05"/>
                      <path d="M228.6 31.4c8.1 0 14.7 2.9 19.7 8.8V34h11.9v55.5c0 7.6-2.1 13.5-6.4 17.8S243.6 114 235 114c-8.1 0-14.8-2.4-20.2-7.3l5-9.2c3.9 3.4 8.9 5.1 14.8 5.1 5.4 0 9.6-1.6 12.5-4.7s4.3-7.6 4.3-13.4V78c-4.9 5.8-11.3 8.7-19.3 8.7-8.2 0-14.9-3.1-20.1-9.2s-7.8-14-7.8-23.7c0-9.5 2.6-17.3 7.8-23.4s12-9.2 20.1-9.2zm2.1 11.6c-4.8 0-8.7 1.9-11.7 5.7s-4.5 9.2-4.5 15.7 1.5 11.8 4.5 15.7 6.9 5.8 11.7 5.8c5 0 9.1-1.9 12.1-5.8s4.5-9.3 4.5-15.8-1.5-11.9-4.5-15.7-7.1-5.6-12.1-5.6z" fill="#4285F4"/>
                      <path d="M269.4 3.7h12.3V87.6h-12.3V3.7z" fill="#34A853"/>
                      <path d="M316.5 31.4c7.9 0 14.2 2.6 19.1 7.9s7.3 12.2 7.3 20.9v4.2H301c.5 5.5 2.3 9.7 5.5 12.8s7.3 4.5 12.2 4.5c6.5 0 12.1-2.4 16.7-7.2l6.5 7.6c-6.1 6.8-14.2 10.2-24.3 10.2-8.5 0-15.4-3-20.7-9.1s-7.9-13.9-7.9-23.5c0-9.6 2.6-17.4 7.9-23.5s12.3-9.1 20.6-9.1zm-7.6 12.1c-4.3 0-7.7 1.4-10.2 4.3s-3.9 6.8-4.2 11.7h28.5c-.3-4.9-1.6-8.8-4.1-11.7s-5.8-4.3-10-4.3z" fill="#EA4335"/>
                    </svg>
                  </div>
                )}

                {/* TRIPADVISOR MATCH */}
                {staffTypedName.includes("tripadvisor") && (
                  <div class="flex items-center gap-1 filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 select-none">
                    <svg class="h-6 w-auto text-[#00AFEF]" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.36 14.83c-.34.34-.8.47-1.19.23-.93-.57-2.1-.9-3.17-.9s-2.24.33-3.17.9c-.39.24-.85.11-1.19-.23l-.7-.7c-.33-.33-.33-.87 0-1.2 1.34-1.34 3.13-2.08 5.06-2.08s3.72.74 5.06 2.08c.33.33.33.87 0 1.2l-.7.7zM7.5 12c-.83 0-1.5-.67-1.5-1.5S6.67 9 7.5 9s1.5 0 .67 1.5-.67 1.5-1.5 1.5zm4.5-4.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm4.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    </svg>
                    <span class="text-[15px] font-black tracking-tight font-sans text-[#004f32]">tripadvisor</span>
                  </div>
                )}

                {/* TRIP.COM MATCH */}
                {staffTypedName.includes("trip.com") && (
                  <div class="flex items-center gap-0.5 filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 select-none font-sans">
                    <span class="text-xl font-extrabold text-[#002F6C] tracking-tight">Trip</span>
                    <span class="text-xl font-extrabold text-[#FF5B00] tracking-tight">.com</span>
                  </div>
                )}

                {/* CTRIP MATCH */}
                {staffTypedName.includes("ctrip") && (
                  <div class="flex flex-col items-center justify-center filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 select-none font-sans leading-none">
                    <span class="text-lg font-black text-[#0066CC] tracking-tight">Ctrip</span>
                    <span class="text-[10px] font-bold text-[#E60012] tracking-wider mt-0.5">携程旅行</span>
                  </div>
                )}

                {/* FALLBACK DEFAULT */}
                {!staffTypedName.includes("booking") && !staffTypedName.includes("traveloka") && !staffTypedName.includes("agoda") && !staffTypedName.includes("google") && !staffTypedName.includes("tripadvisor") && !staffTypedName.includes("trip.com") && !staffTypedName.includes("ctrip") && (
                  <div class="flex items-center gap-1.5 text-amber-700">
                    <span class="text-xs font-bold tracking-wider uppercase font-serif truncate">{badge.name}</span>
                  </div>
                )}
              </div>

              {badge.subtitle && (
                <span class="text-[11px] font-semibold tracking-wide text-slate-500 group-hover:text-amber-700 transition-colors duration-300">
                  {badge.subtitle}
                </span>
              )}
              
            </div>
          );
        })
      }
    </div>
    
    <div class="h-[1px] w-full bg-gradient-to-r from-transparent via-slate-200 to-transparent mt-16"></div>
  </div>
)}
