---
// src/components/stories.astro
import storiesData from "@/content/stories.json";

const rawStories = storiesData || [];
const today = new Date();

const activeStories = rawStories.filter(story => {
  const start = story.start_date ? new Date(story.start_date) : null;
  const expiry = story.expiry_date ? new Date(story.expiry_date) : null;
  if (start && start > today) return false;
  if (expiry && expiry < today) return false;
  return true;
});

const archivedStories = rawStories.filter(story => {
  const expiry = story.expiry_date ? new Date(story.expiry_date) : null;
  return expiry && expiry < today;
});
---

<section class="py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 font-sans overflow-hidden" id="smart-story-section">
  
  {/* Active Stories Layout Section */}
  <div class="space-y-20 md:space-y-28">
    {
      activeStories.map((story, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class="story-card-node grid lg:grid-cols-12 items-center gap-8 md:gap-12 lg:gap-16 bg-slate-50/40 p-6 md:p-8 rounded-2xl border border-slate-100/80 relative">
            
            {/* PHOTO COMPONENT FRAME */}
            <div class={`lg:col-span-5 aspect-[4/3] rounded-xl overflow-hidden bg-slate-100 shadow-sm transition-all duration-700 hover:shadow-md ${isEven ? 'lg:order-1' : 'lg:order-2'}`}>
              {story.story_image && (
                <img 
                  src={story.story_image} 
                  alt={story.title} 
                  class="w-full h-full object-cover transition-transform duration-700 hover:scale-103" 
                  loading="lazy" 
                />
              )}
            </div>
            
            {/* TEXT COMPONENT FRAME */}
            <div class={`lg:col-span-7 flex flex-col justify-center py-2 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
              <div class="story-text-container">
                {story.subtitle && (
                  <span class="text-xs font-semibold tracking-[0.22em] text-amber-600 uppercase mb-2.5 block">
                    {story.subtitle}
                  </span>
                )}
                <h3 class="font-serif text-2xl md:text-3xl text-slate-900 tracking-wide font-normal mb-4 leading-snug">
                  {story.title}
                </h3>
                <p class="text-slate-600 text-[14px] md:text-[15px] leading-relaxed font-light tracking-wide">
                  {story.text_content}
                </p>
              </div>
            </div>

          </div>
        );
      })
    }
  </div>

  {/* NEW: Interactive Click-to-Expand Accordion Archive Section */}
  {archivedStories.length > 0 && (
    <div class="mt-24 pt-12 border-t border-slate-200">
      <div class="mb-10">
        <h4 class="font-serif text-2xl text-slate-800 font-normal">Past Events & Announcements</h4>
        <div class="w-12 h-0.5 bg-slate-300 mt-2"></div>
      </div>
      
      <div class="max-w-4xl space-y-4">
        {archivedStories.map(story => (
          <details class="archive-accordion group bg-slate-50/60 rounded-xl border border-slate-100/80 outline-none transition-all duration-300 open:bg-white open:shadow-md open:border-slate-200">
            
            {/* The Clickable Header Row */}
            <summary class="flex items-center gap-4 p-4 list-none cursor-pointer select-none outline-none focus:outline-none">
              
              {/* Thumbnail Image */}
              <div class="w-20 sm:w-24 h-16 shrink-0 rounded-lg overflow-hidden bg-slate-200 border border-slate-100 shadow-inner">
                {story.story_image && (
                  <img 
                    src={story.story_image} 
                    alt={story.title} 
                    class="archive-thumb w-full h-full object-cover grayscale opacity-80 transition-all duration-500 group-open:grayscale-0 group-open:opacity-100 group-hover:scale-105" 
                  />
                )}
              </div>

              {/* Title Header Text Details */}
              <div class="flex-grow min-w-0 entry-header-wrapper">
                <div class="flex flex-wrap items-center gap-x-2.5 mb-0.5">
                  <span class="text-[9px] font-bold tracking-wider text-slate-400 uppercase">
                    {story.subtitle || "PAST EVENT"}
                  </span>
                  {story.expiry_date && (
                    <span class="text-[10px] text-slate-400/70 font-sans font-light">
                      • Concluded {new Date(story.expiry_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                    </span>
                  )}
                </div>
                
                <h5 class="font-serif text-base text-slate-800 font-medium transition-colors duration-200 group-hover:text-amber-600 group-open:text-slate-900 group-open:font-semibold">
                  {story.title}
                </h5>
              </div>

              {/* Animated Disclosure Caret Indicator Icon */}
              <div class="shrink-0 text-slate-400 pr-2 transition-transform duration-300 transform group-open:rotate-180">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>

            </summary>

            {/* Expanded Content Dropdown Body Panel */}
            <div class="px-4 pb-5 pt-1 sm:pl-[7.5rem] border-t border-dashed border-slate-100 mt-1 transition-all duration-300 animate-fadeIn">
              <p class="text-slate-600 text-sm leading-relaxed font-light tracking-wide max-w-2xl whitespace-pre-line">
                {story.text_content}
              </p>
            </div>

          </details>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  /* Prevent standard chrome/safari default arrow placement icons */
  summary::-webkit-details-marker {
    display: none;
  }
  
  /* Smooth programmatic fading animation block */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.25s ease-out forwards;
  }
</style>
