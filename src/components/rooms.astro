---
// src/components/rooms.astro
import { getCollection } from "astro:content";

// Fetch all room markdown files dynamically from the CMS content collection folder
const cmsRooms = await getCollection("rooms");
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<section id="rooms" class="scroll-mt-24 bg-slate-50 py-20 px-6 border-y border-slate-100">
  <div class="max-w-7xl mx-auto">
    
    {/* Section Header */}
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-amber-600 font-bold text-xs uppercase tracking-widest bg-amber-50 px-3 py-1 rounded-full">Accommodations</span>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mt-3 mb-4">Our Luxurious Rooms & Suites</h2>
      <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-4"></div>
      <p class="text-slate-600 text-sm md:text-base">
        Discover modern comfort fused with historic boutique charm. Our wide array of accommodations provides the perfect sanctuary in the heart of Bandung.
      </p>
    </div>

    {/* Dynamic CMS Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        cmsRooms.map((room) => {
          const { title, description, image, capacity, bed_type, view, features } = room.data;
          
          return (
            <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-slate-100 overflow-hidden flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-1">
              
              <div>
                {/* DYNAMIC CMS IMAGE INTERFACE */}
                <div class="relative overflow-hidden aspect-[4/3] bg-slate-200">
                  {image ? (
                    <img 
                      src={image} 
                      alt={title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    /* Fallback placeholder if staff hasn't uploaded an image yet */
                    <div class="w-full h-full flex flex-col items-center justify-center bg-slate-900 text-slate-400 p-6 text-center">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-amber-500 mb-2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                      </svg>
                      <span class="text-xs font-serif tracking-wider text-slate-300" translate="no">{title} Preview</span>
                    </div>
                  )}
                </div>

                {/* Room Metadata Details Row */}
                <div class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 px-6 py-3 text-xs text-slate-500 font-medium">
                  {capacity && (
                    <span class="flex items-center gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                      </svg>
                      {capacity}
                    </span>
                  )}
                  {bed_type && (
                    <span class="flex items-center gap-1.5 text-right">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                      </svg>
                      {bed_type}
                    </span>
                  )}
                </div>

                {/* Room Summary Content */}
                <div class="p-6">
                  {/* FIXED: Added translate="no" to protect CMS room title fields */}
                  <h3 class="font-serif font-bold text-xl text-slate-900 mb-2 group-hover:text-amber-600 transition-colors" translate="no">
                    {title}
                  </h3>
                  {view && (
                    <p class="text-[11px] text-amber-600 font-bold tracking-wider uppercase mb-3 flex items-center gap-1">
                      <span>•</span> {view}
                    </p>
                  )}
                  <p class="text-slate-600 text-xs md:text-sm leading-relaxed mb-6">
                    {description}
                  </p>

                  {/* Features Pill Matrix */}
                  {features && (
                    <div class="flex flex-wrap gap-2">
                      {features.map((feature: string) => (
                        <span class="text-[11px] font-semibold text-slate-700 bg-slate-100 border border-slate-200/60 px-2.5 py-1 rounded-md">
                          {feature}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              {/* Direct Reservation Link */}
              <div class="p-6 pt-0 mt-auto">
                <a 
                  href="https://m.mutiarahotel.com" 
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full bg-slate-900 hover:bg-amber-600 text-white font-bold text-xs tracking-wider uppercase py-3 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-sm group-hover:shadow-md"
                >
                  <span>Reserve This Suite</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>

            </div>
          )
        })
      }
    </div>

  </div>
</section>
