---
// src/components/rooms.astro
import roomsData from "../content/rooms.json";
---

<section id="rooms" class="scroll-mt-24 bg-slate-50 py-20 px-6 border-y border-slate-100">
  <div class="max-w-7xl mx-auto">
    
    {/* Section Header */}
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-amber-600 font-bold text-xs uppercase tracking-widest bg-amber-50 px-3 py-1 rounded-full">Accommodations</span>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mt-3 mb-4">Our Luxurious Rooms & Suites</h2>
      <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-4"></div>
      <p class="text-slate-600 text-sm md:text-base">
        Discover modern comfort fused with historic boutique charm. Our wide array of accommodations provides the perfect sanctuary in the heart of Bandung.
      </p>
    </div>

    {/* Room Card Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        roomsData.map((room) => (
          <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-slate-100 overflow-hidden flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-1">
            
            <div>
              {/* Card Header with Room Title */}
              <div class="relative bg-slate-900 py-8 px-6 text-white overflow-hidden flex flex-col justify-end min-h-[120px]">
                <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px]"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-slate-900/40 to-transparent"></div>
                
                <div class="relative z-10">
                  <h3 class="font-serif font-bold text-xl md:text-2xl tracking-wide group-hover:text-amber-400 transition-colors">
                    {room.title}
                  </h3>
                  <p class="text-xs text-amber-200 font-medium tracking-wide flex items-center gap-1.5 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    <span>{room.view}</span>
                  </p>
                </div>
              </div>

              {/* Room Metadata */}
              <div class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 px-6 py-3 text-xs text-slate-500 font-medium">
                <span class="flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                  {room.capacity}
                </span>
                <span class="flex items-center gap-1.5 text-right">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                  {room.bed_type}
                </span>
              </div>

              {/* Room Content */}
              <div class="p-6">
                <p class="text-slate-600 text-xs md:text-sm leading-relaxed mb-6">
                  {room.description}
                </p>

                {/* Features Matrix */}
                <div class="flex flex-wrap gap-2">
                  {room.features.map((feature) => (
                    <span class="text-[11px] font-semibold text-slate-700 bg-slate-100 border border-slate-200/60 px-2.5 py-1 rounded-md">
                      {feature}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            {/* CTA Button */}
            <div class="p-6 pt-0 mt-auto">
              <a 
                href="https://m.mutiarahotel.com" 
                target="_blank"
                rel="noopener noreferrer"
                class="w-full bg-slate-900 hover:bg-amber-600 text-white font-bold text-xs tracking-wider uppercase py-3 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-sm group-hover:shadow-md"
              >
                <span>Reserve This Suite</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>

          </div>
        ))
      }
    </div>

  </div>
</section>
