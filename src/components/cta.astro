---
// src/components/cta.astro
import promotionData from "@/content/promotion.json";

// Safely pull variables from your real PagesCMS Promotion Schema
const promo = promotionData || {};
const bgMode = promo.banner_bg_type || "Photo Background";
const uploadedBgImage = promo.banner_bg_image || "/images/pool-night-bg.jpg";
---

<div class="relative max-w-5xl mx-auto my-16 px-4 sm:px-6">
  
  {/* MAIN CONTAINER FRAME */}
  <div class={`relative max-w-4xl mx-auto p-12 md:p-24 text-center group rounded-3xl overflow-hidden min-h-[500px] flex items-center justify-center border transition-all duration-500
    ${bgMode === 'Photo Background' ? 'border-transparent shadow-2xl' : ''}
    ${bgMode === 'Exciting Sunset Gold' ? 'bg-gradient-to-br from-amber-950 via-yellow-900 to-amber-950 border-amber-500/40 shadow-xl' : ''}
    ${bgMode === 'Deep Premium Blue' ? 'bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 border-blue-500/30 shadow-xl' : ''}
  `}>

    {/* PHOTOGRAPHIC CANVAS: Pulls the beautiful ornate frame image you upload in the CMS */}
    {bgMode === 'Photo Background' && (
      <div class="absolute inset-0 z-0">
        <img 
          src={uploadedBgImage} 
          alt="Luxury Promotion Frame" 
          class="w-full h-full object-contain md:object-fill select-none pointer-events-none transform transition-transform duration-700 group-hover:scale-102" 
        />
        {/* Soft center vignette to ensure the white text is readable over the image details */}
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(15,23,42,0.65)_0%,rgba(15,23,42,0.2)_60%,transparent_100%)] pointer-events-none"></div>
      </div>
    )}

    {/* SOLID FALLBACK BACKLIGHT GLOWS (Only show up if Photo Background is turned off) */}
    {bgMode !== 'Photo Background' && (
      <div class="absolute inset-0 bg-black/20 pointer-events-none mix-blend-multiply"></div>
    )}

    {/* TEXT & CONTENT BLOCK */}
    <div class="relative z-20 max-w-xl mx-auto space-y-6 py-4 px-6">
      
      {/* Dynamic Small Upper Tagline Badge */}
      <div class={`inline-flex items-center gap-2 border text-[10px] font-sans font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full backdrop-blur-sm
        ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-500/10 border-amber-400/30 text-amber-400' : ''}
        ${bgMode === 'Deep Premium Blue' ? 'bg-blue-500/10 border-blue-400/30 text-blue-400' : ''}
        ${bgMode === 'Photo Background' ? 'bg-slate-900/80 border-slate-700/50 text-amber-400 shadow-inner' : ''}
      `}>
        <span class={`w-1.5 h-1.5 rounded-full animate-pulse
          ${bgMode === 'Deep Premium Blue' ? 'bg-blue-400' : 'bg-amber-400'}`}></span>
        SPECIAL PROMOTION
      </div>

      {/* Headline Header string input mapping */}
      <h2 class="font-serif text-2xl md:text-4xl text-white tracking-wide leading-tight drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">
        {promo.cta_title || "Exclusive Seasonal Promotion"}
      </h2>

      {/* Decorative Divider Accent */}
      <div class="flex items-center justify-center gap-4 text-amber-500/40">
        <div class="w-12 h-px bg-current"></div>
        <span class="text-xs text-amber-400">✦</span>
        <div class="w-12 h-px bg-current"></div>
      </div>

      {/* Core Paragraph description text context box mapping */}
      <p class="text-slate-100 text-xs md:text-sm leading-relaxed font-light tracking-wide max-w-md mx-auto drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">
        {promo.cta_desc || "Book directly through our website to unlock premium perks..."}
      </p>

      {/* Booking Redirect Action Link Button Path */}
      <div class="pt-2">
        <a
          href="https://direct-reservation.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-300 hover:to-amber-400 text-slate-950 font-sans font-bold text-xs tracking-wider uppercase px-8 py-3.5 rounded-xl shadow-xl shadow-black/30 transition-all duration-200 transform hover:-translate-y-0.5"
        >
          {promo.cta_btn_text || "Claim Offer Now"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</div>
