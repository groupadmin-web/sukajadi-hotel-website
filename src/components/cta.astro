---
import homepageData from "@/content/homepage.json";

const title = homepageData.cta_title || "Exclusive Seasonal Promotion";
const description = homepageData.cta_desc || "Book directly through our website to unlock premium perks, complimentary amenities, and exclusive discounts.";
const buttonText = homepageData.cta_btn_text || "Claim Offer Now";
---

<div class="my-20 max-w-6xl mx-auto px-4 sm:px-6">
  <div class="relative rounded-2xl overflow-hidden bg-slate-950 px-8 py-16 shadow-xl sm:px-16 md:py-20 text-center border border-amber-500/15">
    
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#d97706_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-2xl mx-auto flex flex-col items-center">
      
      {/* PROMOTIONAL BADGE CHIP */}
      <div class="flex items-center gap-2 mb-5 bg-amber-500/10 px-3 py-1 rounded-full border border-amber-500/20 shadow-inner">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-amber-400">Special Promotion</span>
      </div>

      {/* DYNAMIC HEADLINE */}
      <h2 class="text-3xl font-bold font-serif tracking-tight text-white sm:text-4xl leading-tight">
        {title}
      </h2>
      
      {/* OFFER DETAILS */}
      <p class="mt-4 text-base leading-relaxed text-slate-400 font-sans">
        {description}
      </p>
      
      {/* LIVE REDIRECT BOOKING ENGINE LINK */}
      <div class="mt-8">
        <a
          href="https://m.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 rounded-lg bg-amber-500 hover:bg-amber-400 px-7 py-3.5 text-sm font-bold text-slate-950 shadow-md transition-all duration-300 transform hover:-translate-y-0.5 hover:shadow-amber-500/20 font-sans tracking-wide uppercase group/btn select-none"
        >
          <span>{buttonText}</span>
          
          {/* EXCITING ACTION ICON */}
          <svg 
            class="w-4 h-4 text-slate-950 transition-transform duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-110" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</div>
