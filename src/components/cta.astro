---
// src/components/cta.astro
import promotionData from "@/content/promotion.json";

// Safely pull variables from your real PagesCMS Promotion Schema
const promo = promotionData || {};
const bgMode = promo.banner_bg_type || "Photo Background";
const uploadedBgImage = promo.banner_bg_image || "/images/pool-night-bg.jpg";
---

<div class="relative max-w-5xl mx-auto my-16 px-4 sm:px-6">
  
  {/* THE MAIN BOX HOOK */}
  <div class="relative max-w-4xl mx-auto p-12 md:p-20 text-center group rounded-3xl overflow-hidden min-h-[450px] flex items-center justify-center">
    
    {/* MODE 1: Standard generic photo background view layer */}
    {bgMode === 'Photo Background' && (
      <div class="absolute inset-0 z-0">
        <img 
          src={uploadedBgImage} 
          alt="Promotion Background" 
          class="w-full h-full object-cover opacity-35"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900/90 to-slate-950 border border-slate-800 rounded-3xl"></div>
      </div>
    )}

    {/* MODE 2: Exciting Sunset Gold Ornate Luxury Base Wrapper */}
    {bgMode === 'Exciting Sunset Gold' && (
      <div class="absolute inset-0 z-0 pointer-events-none select-none mix-blend-lighten">
        <img 
          src="/images/frame-gold.png" 
          alt="Gold Baroque Luxury Frame" 
          class="w-full h-full object-fill drop-shadow-2xl"
        />
      </div>
    )}

    {/* MODE 3: Deep Premium Blue Ornate Luxury Base Wrapper */}
    {bgMode === 'Deep Premium Blue' && (
      <div class="absolute inset-0 z-0 pointer-events-none select-none mix-blend-lighten">
        <img 
          src="/images/frame-blue.png" 
          alt="Blue Baroque Luxury Frame" 
          class="w-full h-full object-fill drop-shadow-2xl"
        />
      </div>
    )}

    {/* RADIANT AMBIENT LIGHT EFFECT (Sits behind text to make it extremely readable) */}
    <div class="absolute inset-12 z-10 bg-amber-950/40 rounded-full blur-3xl pointer-events-none"></div>

    {/* TEXT & ACTION CONTENT BLOCK CONTROLLERS */}
    <div class="relative z-20 max-w-xl mx-auto space-y-6 py-4 px-6">
      
      {/* Small Dynamic Upper Tagline Badge */}
      <div class={`inline-flex items-center gap-2 border text-[10px] font-sans font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full backdrop-blur-sm
        ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-500/10 border-amber-400/30 text-amber-400' : ''}
        ${bgMode === 'Deep Premium Blue' ? 'bg-blue-500/10 border-blue-400/30 text-blue-400' : ''}
        ${bgMode === 'Photo Background' ? 'bg-slate-800/60 border-slate-700/80 text-slate-300' : ''}
      `}>
        <span class={`w-1.5 h-1.5 rounded-full animate-pulse
          ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-400' : ''}
          ${bgMode === 'Deep Premium Blue' ? 'bg-blue-400' : 'bg-slate-400'}`}></span>
        SPECIAL PROMOTION
      </div>

      {/* Headline Header string input mapping */}
      <h2 class="font-serif text-2xl md:text-4xl text-white tracking-wide leading-tight drop-shadow-md">
        {promo.cta_title || "Exclusive Seasonal Promotion"}
      </h2>

      {/* Decorative Divider Accent */}
      <div class={`flex items-center justify-center gap-4 ${bgMode === 'Exciting Sunset Gold' ? 'text-amber-500/40' : 'text-slate-500/40'}`}>
        <div class="w-12 h-px bg-current"></div>
        <span class="text-xs">✦</span>
        <div class="w-12 h-px bg-current"></div>
      </div>

      {/* Core Paragraph description text context box mapping */}
      <p class="text-slate-200 text-xs md:text-sm leading-relaxed font-light tracking-wide max-w-md mx-auto drop-shadow">
        {promo.cta_desc || "Book directly through our website to unlock premium perks..."}
      </p>

      {/* Booking Redirect Action Link Button Path */}
      <div class="pt-2">
        <a
          href="https://direct-reservation.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class={`inline-flex items-center justify-center gap-2 text-slate-950 font-sans font-bold text-xs tracking-wider uppercase px-8 py-3.5 rounded-xl shadow-lg transition-all duration-200 transform hover:-translate-y-0.5
            ${bgMode === 'Exciting Sunset Gold' ? 'bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-300 hover:to-amber-400 shadow-amber-950/20' : ''}
            ${bgMode === 'Deep Premium Blue' ? 'bg-gradient-to-r from-blue-400 to-indigo-500 hover:from-blue-300 hover:to-indigo-400 shadow-indigo-950/20 text-white' : ''}
            ${bgMode === 'Photo Background' ? 'bg-amber-500 hover:bg-amber-400 text-slate-950 shadow-slate-950/40' : ''}
          `}>
          {promo.cta_btn_text || "Claim Offer Now"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</div>
