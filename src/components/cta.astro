---
// src/components/cta.astro
import promotionData from "@/content/promotion.json";

// Safely pull variables from your real PagesCMS Promotion Schema
const promo = promotionData || {};
const bgMode = promo.banner_bg_type || "Photo Background";
const uploadedBgImage = promo.banner_bg_image || "/images/pool-night-bg.jpg";
---

{/* GRID ALIGNMENT: Set to max-w-7xl px-6 to line up perfectly with the edge of the 3 gallery photos above */}
<div class="relative max-w-7xl mx-auto my-16 px-6">
  
  {/* SHAPED CONTAINER: Increased height 3x using deep py-20/py-28 padding and a 380px minimum height floor */}
  <div class={`relative w-full mx-auto py-20 px-8 md:py-28 md:px-16 text-center group rounded-2xl overflow-hidden min-h-[380px] flex items-center justify-center border transition-all duration-500
    ${bgMode === 'Photo Background' ? 'border-transparent shadow-2xl' : ''}
    ${bgMode === 'Exciting Sunset Gold' ? 'bg-gradient-to-br from-amber-950 via-yellow-900 to-amber-950 border-amber-500/40 shadow-xl' : ''}
    ${bgMode === 'Deep Premium Blue' ? 'bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 border-blue-500/30 shadow-xl' : ''}
  `}>

    {/* PHOTOGRAPHIC CANVAS BACKGROUND */}
    {bgMode === 'Photo Background' && (
      <div class="absolute inset-0 z-0">
        <img 
          src={uploadedBgImage} 
          alt="Luxury Promotion Frame" 
          class="w-full h-full object-cover select-none pointer-events-none transform transition-transform duration-700 group-hover:scale-101" 
        />
        {/* Deep background opacity optimized for a taller vertical viewport */}
        <div class="absolute inset-0 bg-slate-950/50 pointer-events-none"></div>
      </div>
    )}

    {/* AMBIENT CANVAS CONTRAST OVERLAYS */}
    {bgMode !== 'Photo Background' && (
      <div class="absolute inset-0 bg-black/25 pointer-events-none mix-blend-multiply"></div>
    )}

    {/* HORIZONTAL FLEX ENGINE - Spans beautifully from left to right */}
    <div class="relative z-20 w-full flex flex-col md:flex-row items-center justify-between gap-8 text-left">
      
      {/* LEFT CONTENT COLUMN */}
      <div class="space-y-3 max-w-3xl flex-1 text-center md:text-left">
        <div class="flex items-center justify-center md:justify-start gap-2">
          {/* Small Upper Tagline Badge */}
          <div class={`inline-flex items-center gap-1.5 border text-[9px] font-sans font-bold uppercase tracking-[0.18em] px-2.5 py-0.5 rounded-full backdrop-blur-sm
            ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-500/10 border-amber-400/30 text-amber-400' : ''}
            ${bgMode === 'Deep Premium Blue' ? 'bg-blue-500/10 border-blue-400/30 text-blue-400' : ''}
            ${bgMode === 'Photo Background' ? 'bg-slate-900/80 border-slate-700/50 text-amber-400 shadow-inner' : ''}
          `}>
            <span class="w-1 h-1 rounded-full animate-pulse bg-amber-400"></span>
            SPECIAL PROMOTION
          </div>
        </div>

        {/* Headline Header */}
        <h2 class="font-serif text-2xl md:text-4xl text-white tracking-wide leading-tight drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">
          {promo.cta_title || "Exclusive Seasonal Promotion"}
        </h2>

        {/* Core Paragraph */}
        <p class="text-slate-200 text-sm md:text-base leading-relaxed font-light tracking-wide max-w-2xl drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]">
          {promo.cta_desc || "Book directly through our website to unlock premium perks..."}
        </p>
      </div>

      {/* RIGHT ACTION BUTTON COLUMN */}
      <div class="shrink-0 pt-4 md:pt-0 w-full md:w-auto text-center md:text-right">
        <a
          href="https://direct-reservation.sukajadihotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-300 hover:to-amber-400 text-slate-950 font-sans font-bold text-xs tracking-wider uppercase px-8 py-4 rounded-xl shadow-xl shadow-black/30 transition-all duration-200 transform hover:-translate-y-0.5 whitespace-nowrap w-full md:w-auto"
        >
          {promo.cta_btn_text || "Claim Offer Now"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</div>
