---
import promoData from "@/content/promotion.json";

// Safe database configuration data parsing hooks
const title = promoData.cta_title || "Exclusive Seasonal Promotion";
const description = promoData.cta_desc || "Book directly through our website to unlock premium perks, complimentary amenities, and exclusive discounts.";
const buttonText = promoData.cta_btn_text || "Claim Offer Now";

const bgType = promoData.banner_bg_type || "Photo Background";
const bgImage = promoData.banner_bg_image || "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1200&q=80";

let solidBgClass = "bg-slate-950"; 
if (bgType === "Luxury Solid Charcoal") solidBgClass = "bg-gradient-to-br from-slate-900 to-slate-950";
if (bgType === "Deep Premium Blue") solidBgClass = "bg-gradient-to-br from-slate-950 via-[#00224f] to-slate-950";
---

<div class="my-24 max-w-6xl mx-auto px-4 sm:px-6">
  <div class={`relative rounded-2xl overflow-hidden px-8 py-20 shadow-xl sm:px-16 md:py-28 text-center border border-white/10 ${bgType !== "Photo Background" ? solidBgClass : ""}`}>
    
    {/* PHOTO RENDERING MODE ENGINE */}
    {bgType === "Photo Background" && bgImage && (
      <div class="absolute inset-0 z-0 select-none pointer-events-none">
        <img 
          src={bgImage} 
          alt="Mutiara Promo Backdrop" 
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/90 via-slate-950/75 to-slate-950/90 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-slate-950/20 backdrop-blur-[1px]"></div>
      </div>
    )}

    {/* GRADIENT SOLID ELEMENT FILL DECAL */}
    {bgType !== "Photo Background" && (
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#d97706_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>
    )}

    {/* CONTAINER MATRIX HUB CONTENT LAYERS */}
    <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center">
      
      <div class="flex items-center gap-2 mb-6 bg-white/10 px-3 py-1 rounded-full border border-white/10 backdrop-blur-md shadow-sm select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-amber-400 drop-shadow-sm">Special Promotion</span>
      </div>

      <h2 class="text-3xl font-bold font-serif tracking-tight text-white sm:text-5xl leading-tight drop-shadow-sm">
        {title}
      </h2>
      
      <p class="mt-4 text-sm sm:text-base leading-relaxed text-slate-200 font-sans max-w-xl drop-shadow-sm font-medium">
        {description}
      </p>
      
      <div class="mt-8">
        <a
          href="https://m.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 rounded-lg bg-amber-500 hover:bg-amber-400 px-7 py-3.5 text-sm font-bold text-slate-950 shadow-lg transition-all duration-300 transform hover:-translate-y-0.5 hover:shadow-amber-500/30 font-sans tracking-wide uppercase group/btn select-none"
        >
          <span>{buttonText}</span>
          <svg 
            class="w-4 h-4 text-slate-950 transition-transform duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-110" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</div>
