---
// src/components/cta.astro
import promotionData from "@/content/promotion.json";

// Safely pull variables from your real PagesCMS Promotion Schema
const promo = promotionData || {};
const bgMode = promo.banner_bg_type || "Photo Background";
const uploadedBgImage = promo.banner_bg_image || "/images/pool-night-bg.jpg";
---

<div class="relative max-w-4xl mx-auto my-16 px-4 sm:px-6">
  
  {/* THE BADGE SCULPTOR CONTAINER 
    Uses 'clip-path' referencing our custom inline vector path geometry (#promo-badge-mask)
  */}
  <div 
    style="clip-path: url(#promo-badge-mask);"
    class={`relative p-12 md:p-16 text-center group transition-all duration-500 shadow-2xl
      ${bgMode === 'Exciting Sunset Gold' ? 'bg-gradient-to-br from-amber-950 via-yellow-900 to-amber-950' : ''}
      ${bgMode === 'Deep Premium Blue' ? 'bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900' : ''}
      ${bgMode === 'Photo Background' ? 'bg-slate-900' : ''}
    `}
  >

    {/* PHOTO BACKGROUND ENGINE OVERLAY LAYER */}
    {bgMode === 'Photo Background' && (
      <div class="absolute inset-0 z-0">
        <img 
          src={uploadedBgImage} 
          alt="Promotion Background" 
          class="w-full h-full object-cover opacity-25 mix-blend-luminosity"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/90 to-slate-950"></div>
      </div>
    )}

    {/* LUXURY DECORATIVE INNER ACCENT OUTLINE FRAME */}
    <div 
      style="clip-path: url(#promo-badge-mask); inset: 6px;"
      class={`absolute z-10 pointer-events-none border-2 border-dashed opacity-30 transition-opacity duration-300 group-hover:opacity-60
        ${bgMode === 'Exciting Sunset Gold' ? 'border-amber-400' : 'border-blue-400'}
      `}
    ></div>

    {/* BACKGROUND GRADIENT LUMINOUS GLOW LAYERS */}
    <div class={`absolute -top-24 left-1/2 -translate-x-1/2 w-96 h-46 rounded-full blur-3xl pointer-events-none opacity-30
      ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-400' : 'bg-blue-500'}`}></div>
    <div class={`absolute -bottom-24 left-1/2 -translate-x-1/2 w-96 h-46 rounded-full blur-3xl pointer-events-none opacity-30
      ${bgMode === 'Exciting Sunset Gold' ? 'bg-yellow-500' : 'bg-indigo-500'}`}></div>
    
    {/* TEXT & ACTION CONTENT BLOCK CONTROLLERS */}
    <div class="relative z-20 max-w-2xl mx-auto space-y-6 py-4">
      
      {/* Dynamic Small Upper Tagline Badge */}
      <div class={`inline-flex items-center gap-2 border text-[10px] font-sans font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full backdrop-blur-sm
        ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-500/10 border-amber-400/30 text-amber-400' : ''}
        ${bgMode === 'Deep Premium Blue' ? 'bg-blue-500/10 border-blue-400/30 text-blue-400' : ''}
        ${bgMode === 'Photo Background' ? 'bg-slate-800/60 border-slate-700/80 text-slate-300' : ''}
      `}>
        <span class={`w-1.5 h-1.5 rounded-full animate-pulse
          ${bgMode === 'Exciting Sunset Gold' ? 'bg-amber-400' : ''}
          ${bgMode === 'Deep Premium Blue' ? 'bg-blue-400' : 'bg-slate-400'}`}></span>
        SPECIAL PROMOTION
      </div>

      {/* Editable Header Heading string input mapping */}
      <h2 class="font-serif text-3xl md:text-4xl text-white tracking-wide leading-tight">
        {promo.cta_title || "Exclusive Seasonal Promotion"}
      </h2>

      {/* Decorative Divider Accent */}
      <div class={`flex items-center justify-center gap-4 
        ${bgMode === 'Exciting Sunset Gold' ? 'text-amber-500/40' : 'text-slate-500/40'}`}>
        <div class="w-12 h-px bg-current"></div>
        <span class="text-xs">✦</span>
        <div class="w-12 h-px bg-current"></div>
      </div>

      {/* Core Paragraph description text context box mapping */}
      <p class="text-slate-300 text-sm md:text-base leading-relaxed font-light tracking-wide max-w-xl mx-auto">
        {promo.cta_desc || "Book directly through our website to unlock premium perks..."}
      </p>

      {/* Booking Redirect Action Link Button Path */}
      <div class="pt-2">
        <a
          href="https://direct-reservation.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class={`inline-flex items-center justify-center gap-2 text-slate-950 font-sans font-bold text-xs tracking-wider uppercase px-8 py-3.5 rounded-xl shadow-lg transition-all duration-200 transform hover:-translate-y-0.5
            ${bgMode === 'Exciting Sunset Gold' ? 'bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-300 hover:to-amber-400 shadow-amber-950/20' : ''}
            ${bgMode === 'Deep Premium Blue' ? 'bg-gradient-to-r from-blue-400 to-indigo-500 hover:from-blue-300 hover:to-indigo-400 shadow-indigo-950/20 text-white' : ''}
            ${bgMode === 'Photo Background' ? 'bg-amber-500 hover:bg-amber-400 text-slate-950 shadow-slate-950/40' : ''}
          `}>
          {promo.cta_btn_text || "Claim Offer Now"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</div>

{/* VIRTUAL MASK DEFINITION FACTORY
  This vector math definition reshapes the container corners into standard responsive 
  vintage badge lines without ruining performance.
*/}
<svg class="absolute w-0 h-0 pointer-events-none" aria-hidden="true">
  <defs>
    <clipPath id="promo-badge-mask" clipPathUnits="objectBoundingBox">
      <path d="M 0,0.15 
               C 0,0.05 0.05,0 0.15,0 
               L 0.35,0 
               C 0.4,0.03 0.45,0.05 0.5,0.05 
               C 0.55,0.05 0.6,0.03 0.65,0 
               L 0.85,0 
               C 0.95,0 1,0.05 1,0.15 
               L 1,0.35 
               C 0.97,0.4 0.95,0.45 0.95,0.5 
               C 0.95,0.55 0.97,0.6 1,0.65 
               L 1,0.85 
               C 1,0.95 0.95,1 0.85,1 
               L 0.65,1 
               C 0.6,0.97 0.55,0.95 0.5,0.95 
               C 0.45,0.95 0.4,0.97 0.35,1 
               L 0.15,1 
               C 0.05,1 0,0.95 0,0.85 
               L 0,0.65 
               C 0.03,0.6 0.05,0.55 0.05,0.5 
               C 0.05,0.45 0.03,0.4 0,0.35 
               Z" />
    </clipPath>
  </defs>
</svg>
