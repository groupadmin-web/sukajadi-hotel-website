---
// src/components/BookingToast.astro
import toastSettings from "../content/booking_toast.json";

const initialThresholdMs = (toastSettings.initial_threshold_seconds || 30) * 1000;
const cooldownMs = (toastSettings.cooldown_loop_minutes || 3) * 60 * 1000;

// SECURE MASKING ENGINE
const targetEmail = toastSettings.email_address || "info@mutiarahotel.com";
const base64MaskedEmail = Buffer.from(targetEmail).toString('base64');
const encodedSubject = encodeURIComponent(toastSettings.email_subject || "Direct Concierge Booking Inquiry");
---

<div 
  id="booking-toast-container"
  data-initial-threshold={initialThresholdMs}
  data-cooldown-length={cooldownMs}
  class="fixed bottom-6 right-6 z-[999] max-w-sm w-full bg-slate-900 border border-slate-800 text-slate-300 rounded-xl p-4 shadow-2xl"
  style="opacity: 0; pointer-events: none; transform: translateY(40px); transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;"
>
  <div class="flex items-start gap-3 relative">
    
    <!-- CIRCLE BADGE WRAPPER WITH NATIVE FOOTER SVG MATCH -->
    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-500 select-none animate-pulse">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
    </div>

    <!-- MAIN TEXT LAYOUT -->
    <div class="flex-1 pr-4">
      <h5 class="text-white text-xs font-bold uppercase tracking-wider mb-1 font-sans">
        {toastSettings.heading}
      </h5>
      <p class="text-[11px] leading-relaxed text-slate-400 font-light">
        {toastSettings.description}
      </p>
      
      <!-- PRIMARY CTAs GRID LINK ROW -->
      <div class="mt-4 flex flex-wrap items-center gap-2 text-[10px] font-sans font-bold uppercase tracking-wider">
        <!-- PRIMARY DIRECT BOOK NOW ACTION -->
        <a 
          href="https://m.mutiarahotel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-amber-500 hover:bg-amber-400 text-slate-950 px-2.5 py-1 rounded font-bold transition-colors shadow-sm"
        >
          Book Now
        </a>

        <span class="text-slate-800">|</span>

        <!-- CALL BACKEND NAVIGATION -->
        <a 
          href={`tel:${toastSettings.call_phone_number.replace(/\s+/g, '')}`} 
          class="text-slate-300 hover:text-white transition-colors p-1"
        >
          {toastSettings.call_button_text}
        </a>
        
        <span class="text-slate-800">|</span>
        
        <!-- SECURE MASKED EMAIL LINK -->
        <a 
          id="toast-secure-email-link"
          data-m={base64MaskedEmail}
          data-s={encodedSubject}
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-white transition-colors p-1"
        >
          {toastSettings.email_button_text}
        </a>
      </div>
    </div>

    <!-- DISMISS CONTAINER BUTTON -->
    <button 
      id="toast-close-btn"
      class="absolute -top-1 -right-1 text-slate-500 hover:text-white text-base font-sans leading-none focus:outline-none cursor-pointer p-1 select-none"
      aria-label="Dismiss reminder"
    >
      ×
    </button>
  </div>
</div>

<script is:inline>
  function initBookingToast() {
    const container = document.getElementById('booking-toast-container');
    const closeBtn = document.getElementById('toast-close-btn');
    const secureEmailLink = document.getElementById('toast-secure-email-link');

    if (!container) return;

    const initialThreshold = parseInt(container.getAttribute('data-initial-threshold') || '30000', 10);
    const cooldownLength = parseInt(container.getAttribute('data-cooldown-length') || '180000', 10);

    const showToast = () => {
      container.style.opacity = '1';
      container.style.pointerEvents = 'auto';
      container.style.transform = 'translateY(0)';
    };

    const hideToast = () => {
      container.style.opacity = '0';
      container.style.pointerEvents = 'none';
      container.style.transform = 'translateY(40px)';
    };

    const checkTimer = () => {
      const now = Date.now();
      let elapsed = parseInt(localStorage.getItem('site_dwell_time') || '0', 10);
      
      if (elapsed < initialThreshold) {
        localStorage.setItem('site_dwell_time', (elapsed + 1000).toString());
        return; 
      }

      const cooldownExpiry = parseInt(localStorage.getItem('toast_cooldown_expiry') || '0', 10);
      if (cooldownExpiry > 0) {
        if (now < cooldownExpiry) return; 
        localStorage.removeItem('toast_cooldown_expiry');
      }

      showToast();
    };

    // EMAIL UNMASK UTILITIES
    if (secureEmailLink) {
      const unmaskAndGo = () => {
        const masked = secureEmailLink.getAttribute('data-m');
        const subject = secureEmailLink.getAttribute('data-s');
        if (masked) {
          const realEmail = atob(masked);
          secureEmailLink.href = `mailto:${realEmail}?subject=${subject}`;
        }
      };

      secureEmailLink.addEventListener('mousedown', unmaskAndGo);
      secureEmailLink.addEventListener('touchstart', unmaskAndGo, { passive: true });
      secureEmailLink.addEventListener('mouseenter', unmaskAndGo);
    }

    if (window.toastTimerInterval) {
      clearInterval(window.toastTimerInterval);
    }
    window.toastTimerInterval = setInterval(checkTimer, 1000);

    closeBtn?.addEventListener('click', () => {
      hideToast();
      localStorage.setItem('toast_cooldown_expiry', (Date.now() + cooldownLength).toString());
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBookingToast);
  } else {
    initBookingToast();
  }

  document.addEventListener('astro:after-swap', initBookingToast);
</script>
