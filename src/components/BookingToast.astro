---
// src/components/BookingToast.astro
import toastSettings from "../content/booking_toast.json";

// Safely pull configuration rules from the CMS JSON file
const initialThresholdSeconds = toastSettings.initial_threshold_seconds || 30;
const cooldownMinutes = toastSettings.cooldown_loop_minutes || 3;
---

<div 
  x-data="{ showToast: false }"
  x-init={`
    // Convert thresholds cleanly inside the client runtime engine
    const initialThreshold = ${initialThresholdSeconds} * 1000; 
    const cooldownLength = ${cooldownMinutes} * 60 * 1000; 

    const checkTimer = () => {
      const now = Date.now();
      
      // Accumulate browsing durations natively inside localStorage
      let elapsed = parseInt(localStorage.getItem('site_dwell_time') || '0', 10);
      if (elapsed < initialThreshold) {
        localStorage.setItem('site_dwell_time', (elapsed + 1000).toString());
        return; 
      }

      // Check if the 3-minute cooldown loop block is ticking down
      const cooldownExpiry = parseInt(localStorage.getItem('toast_cooldown_expiry') || '0', 10);
      
      if (cooldownExpiry > 0) {
        if (now < cooldownExpiry) {
          return; 
        } else {
          localStorage.removeItem('toast_cooldown_expiry');
        }
      }

      if (!showToast) {
        showToast = true;
      }
    };

    // Keep ticking in the background every 1 second
    let timerInterval = setInterval(checkTimer, 1000);
  `}
  class="fixed bottom-6 right-6 z-[999] max-w-sm w-full bg-slate-900 border border-slate-800 text-slate-300 rounded-xl p-4 shadow-2xl transition-all duration-500 transform pointer-events-auto"
  x-show="showToast"
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 translate-y-10 scale-95"
  x-transition:enter-end="opacity-100 translate-y-0 scale-100"
  x-transition:leave="transition ease-in duration-300"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 translate-y-4"
  style="display: none;"
>
  <div class="flex items-start gap-3 relative">
    {/* Dynamic CMS Icon Badge */}
    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-500 text-sm font-sans animate-pulse select-none">
      {toastSettings.badge_icon}
    </div>

    {/* Content Areas managed by CMS */}
    <div class="flex-1 pr-4">
      <h5 class="text-white text-xs font-bold uppercase tracking-wider mb-1 font-sans">
        {toastSettings.heading}
      </h5>
      <p class="text-[11px] leading-relaxed text-slate-400 font-light">
        {toastSettings.description}
      </p>
      
      {/* Action Links */}
      <div class="mt-3 flex items-center gap-3 text-[10px] font-sans font-bold uppercase tracking-wider">
        <a 
          href={`tel:${toastSettings.call_phone_number.replace(/\s+/g, '')}`} 
          class="text-amber-500 hover:text-amber-400 transition-colors flex items-center gap-1 group"
        >
          <span>{toastSettings.call_button_text}</span>
          <span class="transform group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <span class="text-slate-800">|</span>
        <button 
          @click="document.getElementById('direct-concierge-action')?.click()"
          class="text-slate-400 hover:text-white transition-colors cursor-pointer"
        >
          {toastSettings.email_button_text}
        </button>
      </div>
    </div>

    {/* Dismiss Trigger: Multiplies minutes into active runtime milliseconds dynamically */}
    <button 
      @click={`showToast = false; localStorage.setItem('toast_cooldown_expiry', (Date.now() + (${cooldownMinutes} * 60 * 1000)).toString());`}
      class="absolute -top-1 -right-1 text-slate-500 hover:text-white text-base font-sans leading-none focus:outline-none cursor-pointer p-1 select-none"
      aria-label="Dismiss reminder"
    >
      ×
    </button>
  </div>
</div>
