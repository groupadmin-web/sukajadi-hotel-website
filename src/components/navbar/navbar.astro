---
// src/components/navbar/navbar.astro
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

// Fetch your dynamic brand data from your header setup file
import homepageData from "@/content/homepage.json";

// FETCH & NORMALIZE CURRENT PAGE ROUTE (Case-insensitive & handles trailing slashes perfectly)
const requestUrlPath = new URL(Astro.request.url).pathname;
const currentPath = requestUrlPath.toLowerCase().replace(/\/$/, "") || "/";

const menuitems = [
  { title: "HOME", path: "/" },
  { title: "ROOMS", path: "/rooms" },
  { title: "FOOD", path: "/food" }, // 🟢 NEW: Direct route to your brand-new dynamic dining catalog
  { title: "TOURIST ATTRACTIONS", path: "/attractions" },
  { title: "GALLERY", path: "/gallery" },
  { title: "MEETINGS & EVENTS", path: "/meetings-events" },
  { title: "Q&A", path: "/qna" }, 
  { title: "CONTACT", path: "/#footer" }, 
];
---

{/* FIXED LAYER DEFLATION: Changed z-[100] back to z-40 so the language capsule floats cleanly on top */}
<header class="sticky top-0 z-40 w-full bg-white shadow-sm transition-all border-b border-gray-100">
  <Container>
    <div class="flex flex-col lg:flex-row justify-between items-center py-4 w-full min-h-[72px] lg:min-h-0">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between relative">
          
          <a href="/" class="flex items-center tracking-wider font-serif group">
            {homepageData.logo_image ? (
              <img 
                src={homepageData.logo_image} 
                alt="Sukajadi Hotel & Convention Bandung Logo" 
                class="h-12 md:h-16 w-auto object-contain max-w-[160px] md:max-w-[200px] transition-transform duration-300 group-hover:scale-105" 
              />
            ) : (
              <span class="font-bold text-xl text-slate-900 uppercase">
                {homepageData.logo_text || "MUTIARA"}
              </span>
            )}
          </a>
          
          {/* 5PX VERTICAL CENTER FIX: Set to top-[17px] and z-50 to cleanly catch user interactions */}
          <div class="block lg:hidden absolute top-[17px] right-1 z-50 text-slate-950 hover:text-amber-600 transition-colors cursor-pointer p-1">
            <MenuIcon class="w-6 h-6" />
          </div>
        </div>
        
        {/* Menu items container dropdown block - Pushed to z-50 to safely clear basic content blocks */}
        <MenuItems class="hidden w-full lg:w-auto mt-4 pt-14 lg:pt-0 lg:flex lg:mt-0 relative z-50">
          <ul class="flex flex-col lg:flex-row items-start lg:items-center gap-1 lg:gap-2 w-full">
            {
              menuitems.map((item, index) => {
                const itemNormalizedPath = item.path.toLowerCase().replace(/\/$/, "") || "/";
                const isActive = itemNormalizedPath === "/" 
                  ? currentPath === "/" 
                  : currentPath.startsWith(itemNormalizedPath);

                return (
                  <>
                    {item.children && (
                      <Dropdown
                        title={item.title}
                        children={item.children}
                        lastItem={index === menuitems.length - 1}
                      />
                    )}

                    {!item.children && (
                      <li class="w-full lg:w-auto">
                        <a
                          href={item.path}
                          class={`nav-item flex lg:px-3 py-2 items-center text-sm font-bold tracking-wide transition-all uppercase relative after:absolute after:bottom-0 after:left-3 after:right-3 after:h-0.5 after:bg-amber-600 after:transition-transform after:duration-300 ${
                            isActive 
                              ? "text-amber-600 after:scale-x-100" 
                              : "text-slate-700 hover:text-amber-600 after:scale-x-0 hover:after:scale-x-100"
                          }`}
                        >
                          <span>{item.title}</span>
                        </a>
                      </li>
                    )}
                  </>
                );
              })
            }
          </ul>
          
          <div class="lg:hidden flex items-center mt-4 w-full pb-4">
            <a 
              href="https://m.sukajadihotel.com" 
              class="w-full bg-amber-600 hover:bg-amber-700 text-white font-bold text-base py-3 rounded-md shadow-md transition-all flex items-center justify-center gap-2 tracking-wide"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-amber-100">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
              </svg>
              <span>Book Now</span>
            </a>
          </div>
        </MenuItems>
      </Astronav>
      
      <div class="hidden lg:flex items-center">
        <a 
          href="https://m.sukajadihotel.com" 
          class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-sm px-5 py-2.5 rounded-md shadow-md transition-all flex items-center justify-center gap-2 tracking-wide"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-amber-100">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
          </svg>
          <span>Book Now</span>
        </a>
      </div>
    </div>
  </Container>
</header>
