---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Mutiara Hotel"
  : "Mutiara Hotel - Premium Accommodations";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="Welcome to Mutiara Hotel. Book your stay with us directly for premium service and accommodation."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Mutiara Hotel`,
          image: resolvedImageWithDomain,
        },
      }}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
  </head>
  <body>
    
    <div class="fixed top-4 right-4 z-[999999] pointer-events-auto sm:right-6 notranslate">
      <div class="bg-white/95 backdrop-blur-md px-3 py-1.5 rounded-full flex items-center gap-2.5 border border-slate-200/90 shadow-lg transition-all duration-300">
        
        <span id="global-lang-label" class="text-[9px] tracking-wide font-sans font-semibold text-slate-400 uppercase pr-0.5 select-none hidden xs:inline-block">
          SELECT LANGUAGE:
        </span>

        <div class="w-[1px] h-3 bg-slate-200 hidden xs:inline-block"></div>

        <button 
          id="global-nav-en" 
          type="button" 
          class="w-5 h-5 rounded-full overflow-hidden transition-all duration-200 hover:scale-110 cursor-pointer flex items-center justify-center select-none outline-none transition-shadow aspect-square shrink-0"
          title="English"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" preserveAspectRatio="none" class="w-full h-full object-cover block pointer-events-none">
            <clipPath id="s"><path d="M0 0h60v30H0z"/></clipPath>
            <g clip-path="url(#s)">
              <path d="M0 0h60v30H0z" fill="#012169"/>
              <path d="M0 0l60 30M60 0L0 30" stroke="#fff" stroke-width="6"/>
              <path d="M0 0l60 30M60 0L0 30" stroke="#c8102e" stroke-width="4"/>
              <path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10"/>
              <path d="M30 0v30M0 15h60" stroke="#c8102e" stroke-width="6"/>
            </g>
          </svg>
        </button>

        <div class="w-[1px] h-3 bg-slate-200"></div>

        <button 
          id="global-nav-id" 
          type="button" 
          class="w-5 h-5 rounded-full overflow-hidden transition-all duration-200 hover:scale-110 cursor-pointer flex items-center justify-center select-none outline-none transition-shadow aspect-square shrink-0"
          title="Indonesia"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3 2" preserveAspectRatio="none" class="w-full h-full object-cover block pointer-events-none">
            <path fill="#e21c0e" d="M0 0h3v1H0z"/>
            <path fill="#fff" d="M0 1h3v1H0z"/>
          </svg>
        </button>

      </div>
    </div>

    <div class="notranslate">
      <Navbar />
    </div>

    <slot />

    <div class="notranslate">
      <Footer />
    </div>

    <a href="https://wa.me/6287722469110" class="whatsapp-icon-float notranslate" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" class="whatsapp-svg">
        <path fill="#FFF" d="M12.012 2c-5.508 0-9.988 4.479-9.988 9.987 0 1.763.459 3.49 1.33 5.009l-1.353 4.937 5.055-1.326c1.47.8 3.125 1.222 4.814 1.223h.004c5.507 0 9.989-4.479 9.989-9.988 0-2.67-1.039-5.18-2.93-7.071C17.186 3.04 14.684 2 12.012 2zm5.727 14.043c-.235.662-1.36 1.205-1.879 1.282-.46.069-1.06.126-3.155-.701-2.678-1.057-4.407-3.786-4.542-3.963-.133-.177-1.082-1.437-1.082-2.742 0-1.306.683-1.948.924-2.214.241-.265.529-.332.706-.332.176 0 .353.003.507.01.16.007.375-.062.587.447.218.524.743 1.812.808 1.945.066.133.11.287.022.463-.088.177-.133.287-.265.442-.132.155-.278.347-.396.465-.133.133-.272.278-.118.543.155.265.687 1.134 1.474 1.833.1.089.197.177.291.26.702.615 1.295.82 1.57.954.276.133.438.11.603-.078.166-.188.706-.818.894-1.094.188-.276.376-.232.631-.138.254.094 1.61.76 1.886.898.276.138.459.208.526.32.066.111.066.645-.169 1.307z"/>
      </svg>
    </a>

    <style is:global>
      img {
        content-visibility: auto;
      }
      .whatsapp-icon-float {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background-color: #25d366;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.3);
        z-index: 99999;
        transition: transform 0.2s ease, background-color 0.2s ease;
      }
      .whatsapp-svg {
        width: 36px;
        height: 36px;
      }
      .whatsapp-icon-float:hover {
        transform: scale(1.1);
        background-color: #128c7e;
      }
      @media (max-width: 768px) {
        .whatsapp-icon-float {
          bottom: 16px;
          right: 16px;
          width: 50px;
          height: 50px;
        }
        .whatsapp-svg {
          width: 30px;
          height: 30px;
        }
      }
      @media (max-width: 400px) {
        .hidden.xs\:inline-block {
          display: none !important;
        }
      }
    </style>

    <script is:inline>
      function getLanguageSetting() {
        return new URLSearchParams(window.location.search).get('lang') === 'id' ? 'id' : 'en';
      }

      function executeGlobalTranslation() {
        const targetLang = getLanguageSetting();
        const flagEN = document.getElementById('global-nav-en');
        const flagID = document.getElementById('global-nav-id');
        const labelEl = document.getElementById('global-lang-label');
        
        if (!flagEN || !flagID) return;

        if (targetLang === 'id') {
          flagID.style.filter = 'none'; flagID.style.opacity = '1'; flagID.style.transform = 'scale(1.2)';
          flagID.style.boxShadow = '0 0 0 2px #d97706, 0 4px 6px -1px rgba(0,0,0,0.1)';
          flagEN.style.filter = 'grayscale(100%) brightness(85%)'; flagEN.style.opacity = '0.3'; flagEN.style.transform = 'scale(0.9)'; flagEN.style.boxShadow = 'none';
          if (labelEl) labelEl.innerText = "PILIHAN BAHASA:";
        } else {
          flagEN.style.filter = 'none'; flagEN.style.opacity = '1'; flagEN.style.transform = 'scale(1.2)';
          flagEN.style.boxShadow = '0 0 0 2px #d97706, 0 4px 6px -1px rgba(0,0,0,0.1)';
          flagID.style.filter = 'grayscale(100%) brightness(85%)'; flagID.style.opacity = '0.3'; flagID.style.transform = 'scale(0.9)'; flagID.style.boxShadow = 'none';
          if (labelEl) labelEl.innerText = "SELECT LANGUAGE:";
        }

        window.dispatchEvent(new CustomEvent('globalLangChange', { detail: { lang: targetLang } }));
      }

      function setupLanguageListeners() {
        const btnEN = document.getElementById('global-nav-en');
        const btnID = document.getElementById('global-nav-id');

        if (btnEN) {
          btnEN.onclick = () => {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', 'en');
            window.history.pushState({}, '', url);
            executeGlobalTranslation();
          };
        }

        if (btnID) {
          btnID.onclick = () => {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', 'id');
            window.history.pushState({}, '', url);
            executeGlobalTranslation();
          };
        }
      }

      setupLanguageListeners();
      executeGlobalTranslation();

      document.addEventListener('astro:after-swap', () => {
        setupLanguageListeners();
        executeGlobalTranslation();
      });
    </script>
  </body>
</html>
