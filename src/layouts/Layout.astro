---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Mutiara Hotel"
  : "Mutiara Hotel - Premium Accommodations";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="Welcome to Mutiara Hotel. Book your stay with us directly for premium service and accommodation."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Mutiara Hotel`,
          image: resolvedImageWithDomain,
        },
      }}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
  </head>
  <body>
    
    <div class="fixed top-4 right-4 z-[999999] pointer-events-auto sm:right-6">
      <div class="bg-white/90 backdrop-blur-md px-2 py-1 rounded-full flex items-center gap-1.5 border border-slate-200/80 shadow-md transition-all duration-300 hover:border-slate-300">
        <button 
          id="global-nav-en" 
          type="button" 
          class="p-1 rounded-full transition-all duration-200 hover:scale-110 cursor-pointer text-base leading-none select-none"
          title="English"
        >
          🇬🇧
        </button>
        <div class="w-[1px] h-3 bg-slate-300"></div>
        <button 
          id="global-nav-id" 
          type="button" 
          class="p-1 rounded-full transition-all duration-200 hover:scale-110 cursor-pointer text-base leading-none select-none"
          title="Indonesia"
        >
          🇮🇩
        </button>
      </div>
    </div>

    <Navbar />
    <slot />
    <Footer />

    <a href="https://wa.me/6287722469110" class="whatsapp-icon-float" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" class="whatsapp-svg">
        <path fill="#FFF" d="M12.012 2c-5.508 0-9.988 4.479-9.988 9.987 0 1.763.459 3.49 1.33 5.009l-1.353 4.937 5.055-1.326c1.47.8 3.125 1.222 4.814 1.223h.004c5.507 0 9.989-4.479 9.989-9.988 0-2.67-1.039-5.18-2.93-7.071C17.186 3.04 14.684 2 12.012 2zm5.727 14.043c-.235.662-1.36 1.205-1.879 1.282-.46.069-1.06.126-3.155-.701-2.678-1.057-4.407-3.786-4.542-3.963-.133-.177-1.082-1.437-1.082-2.742 0-1.306.683-1.948.924-2.214.241-.265.529-.332.706-.332.176 0 .353.003.507.01.16.007.375-.062.587.447.218.524.743 1.812.808 1.945.066.133.11.287.022.463-.088.177-.133.287-.265.442-.132.155-.278.347-.396.465-.133.133-.272.278-.118.543.155.265.687 1.134 1.474 1.833.1.089.197.177.291.26.702.615 1.295.82 1.57.954.276.133.438.11.603-.078.166-.188.706-.818.894-1.094.188-.276.376-.232.631-.138.254.094 1.61.76 1.886.898.276.138.459.208.526.32.066.111.066.645-.169 1.307z"/>
      </svg>
    </a>

    <style is:global>
      img {
        content-visibility: auto;
      }
      .whatsapp-icon-float {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background-color: #25d366;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.3);
        z-index: 99999;
        transition: transform 0.2s ease, background-color 0.2s ease;
      }
      .whatsapp-svg {
        width: 36px;
        height: 36px;
      }
      .whatsapp-icon-float:hover {
        transform: scale(1.1);
        background-color: #128c7e;
      }
      @media (max-width: 768px) {
        .whatsapp-icon-float {
          bottom: 16px;
          right: 16px;
          width: 50px;
          height: 50px;
        }
        .whatsapp-svg {
          width: 30px;
          height: 30px;
        }
      }
    </style>

    <script is:inline>
      const globalTranslations = {
        id: {
          "accomm-sub": "AKOMODASI",
          "accomm-title": "Penginapan Butik Kolonial yang Abadi",
          "accomm-desc": "Dengan 112 kamar yang ditata indah di 6 lantai, Mutiara Hotel & Convention memadukan lantai ubin otentik dan tata letak kayu klasik dengan kenyamanan modern. Dari kamar budget yang nyaman hingga suite keluarga multi-kamar yang luas, setiap ruang kedap suara sepenuhnya dan ber-AC untuk menjadi tempat perlindungan pribadi Anda.",
          "leisure-sub": "REKREASI & KETENANGAN",
          "leisure-title": "Keramahtamahan Otentik di Sisi Kolam Renang Kristal",
          "leisure-desc": "Lepaskan penat dari kesibukan Pasirkaliki di dalam taman halaman kami yang damai. Nikmati pagi Anda dengan sarapan lezat di Restoran Tiara dengan pemandangan air langsung, atau bersantai di kursi berjemur premium di tepi kolam renang sementara layanan pramutamu dan meja layanan tamu 24 jam kami mengurus setiap kebutuhan perjalanan Anda."
        },
        en: {
          "accomm-sub": "THE ACCOMMODATIONS",
          "accomm-title": "Timeless Colonial Boutique Lodging",
          "accomm-desc": "With 112 beautifully arranged rooms stretching across 6 floors, Mutiara Hotel & Convention pairs authentic tiled floors and classic woodwork layouts with modern comforts. From cozy budget stays to sprawling multi-room family suites, every space is fully soundproofed and air-conditioned to serve as your private sanctuary.",
          "leisure-sub": "LEISURE & CALM",
          "leisure-title": "Authentic Hospitality by the Crystalline Pool",
          "leisure-desc": "Escape the bustle of Pasirkaliki inside our peaceful courtyard garden. Spend your mornings enjoying a hearty breakfast at Tiara Restaurant with direct views of the water, or lounge on our premium poolside sun chairs while our 24-hour concierge and guest service desk takes care of your every travel requirement."
        }
      };

      function getLanguageSetting() {
        return new URLSearchParams(window.location.search).get('lang') === 'id' ? 'id' : 'en';
      }

      function applyGlobalTranslation() {
        const lang = getLanguageSetting();
        const flagEN = document.getElementById('global-nav-en');
        const flagID = document.getElementById('global-nav-id');
        
        if (!flagEN || !flagID) return;

        // Clean flag styling toggles using style filters instead of modifying classes
        if (lang === 'id') {
          flagID.style.filter = 'grayscale(0%)';
          flagID.style.opacity = '1';
          flagID.style.transform = 'scale(1.1)';
          
          flagEN.style.filter = 'grayscale(80%)';
          flagEN.style.opacity = '0.4';
          flagEN.style.transform = 'scale(1)';
        } else {
          flagEN.style.filter = 'grayscale(0%)';
          flagEN.style.opacity = '1';
          flagEN.style.transform = 'scale(1.1)';
          
          flagID.style.filter = 'grayscale(80%)';
          flagID.style.opacity = '0.4';
          flagID.style.transform = 'scale(1)';
        }

        document.querySelectorAll('[data-translate-key]').forEach(el => {
          const key = el.getAttribute('data-translate-key');
          if (globalTranslations[lang] && globalTranslations[lang][key]) {
            el.innerText = globalTranslations[lang][key];
          }
        });
        
        window.dispatchEvent(new CustomEvent('globalLangChange', { detail: { lang } }));
      }

      function setupLanguageListeners() {
        const btnEN = document.getElementById('global-nav-en');
        const btnID = document.getElementById('global-nav-id');

        if (btnEN) {
          btnEN.onclick = () => {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', 'en');
            window.history.pushState({}, '', url);
            applyGlobalTranslation();
          };
        }

        if (btnID) {
          btnID.onclick = () => {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', 'id');
            window.history.pushState({}, '', url);
            applyGlobalTranslation();
          };
        }
      }

      setupLanguageListeners();
      applyGlobalTranslation();

      document.addEventListener('astro:after-swap', () => {
        setupLanguageListeners();
        applyGlobalTranslation();
      });
    </script>
  </body>
</html>
