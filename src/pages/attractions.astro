---
// src/pages/attractions.astro
import Layout from "../layouts/Layout.astro";
import attractionsData from "../content/attractions.json";

const attractions = Array.isArray(attractionsData) ? attractionsData : [];
---

<Layout title="Local Attractions | Mutiara Hotel & Convention">
  <div class="bg-gray-50 min-h-screen py-16 px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-4xl mx-auto text-center mb-16 mt-8">
      <span class="text-amber-600 font-sans text-xs tracking-widest uppercase font-bold block mb-1">Explore Bandung</span>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-gray-900 tracking-wide uppercase mb-4">
        Destinations & Attractions
      </h1>
      <div class="w-24 h-1 bg-amber-600 mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-light max-w-2xl mx-auto italic">
        "From the heritage steps of the historic city center to the dramatic volcanic craters of West Java, experience the best of Bandung right from our doorstep."
      </p>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {attractions.map((item) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
          
          <div class="relative h-60 bg-gray-200 overflow-hidden">
            <img 
              src={item.image} 
              alt={item.title} 
              class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
            
            <div class="absolute top-4 right-4 bg-gray-900/80 backdrop-blur-sm text-white text-[9px] tracking-widest uppercase px-2.5 py-1 rounded font-sans font-semibold">
              {item.category}
            </div>

            <div class="absolute bottom-4 left-4 bg-slate-950/80 backdrop-blur-sm text-white text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-md font-sans font-medium flex items-center gap-1.5 shadow-md">
              <span>📍</span> {item.distance}
            </div>
          </div>

          <div class="p-6 flex-grow flex flex-col justify-between">
            <div>
              <span class="text-amber-600 text-[10px] tracking-widest uppercase font-sans font-bold block mb-1">
                {item.tagline}
              </span>
              <h2 class="text-xl font-serif font-bold text-gray-800 mb-3 uppercase tracking-wide line-clamp-2 min-h-[56px] flex items-center">
                {item.title}
              </h2>
              <div class="w-8 h-0.5 bg-gray-200 mb-4"></div>
              <p class="text-gray-500 text-sm font-sans font-light leading-relaxed line-clamp-4">
                {item.description}
              </p>
            </div>

            <div class="border-t border-gray-100 pt-4 mt-6 flex items-center justify-between text-[11px] font-sans font-medium tracking-wider text-slate-400 uppercase">
              <span>Bandung, IDN</span>
              <span class="text-amber-600 font-bold">Local Guide →</span>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</Layout>
