---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";

import Rooms from "../components/rooms.astro";
import Stories from "../components/stories.astro"; 
import Archive from "../components/archive.astro"; 

// DYNAMIC SITE DATA PAYLOAD ENGINES
import reviewsData from "@/content/reviews.json";
import galleryData from "@/content/gallery.json";
import eventData from "@/content/events.json";

// Isolate top items for homepage sneak peeks
const homeGalleryTeasers = (galleryData || []).slice(0, 3);
const homeEventItems = eventData || [];

// Sort client review structures chronologically
const sortedReviews = (reviewsData || []).sort((a, b) => {
  return new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime();
});

const isSlider = sortedReviews.length > 4;
---

<Layout title="Mutiara Hotel & Convention">
  
  <div id="universal-translation-root">
    
    <Hero />

    <Features />

    {/* GUEST REVIEWS MARQUEE SECTION: Placed directly above the Stories block */}
    <section class="reviews-section my-16 px-6 max-w-7xl mx-auto overflow-hidden">
      <h2 class="text-center text-3xl font-bold mb-2 text-gray-800">What Our Guests Love About Us</h2>
      <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-10"></div>
      
      <div class="marquee-viewport">
        <div class={`marquee-track ${isSlider ? 'animate-marquee' : 'justify-center'}`}>
          
          <div class="marquee-group">
            {
              sortedReviews.map((review) => (
                <div class="review-card">
                  <div>
                    <div class="stars notranslate">
                      {review.stars && review.stars.toString().includes("5") && "⭐⭐⭐⭐⭐"}
                      {review.stars && review.stars.toString().includes("4") && "⭐⭐⭐⭐"}
                      {review.stars && review.stars.toString().includes("3") && "⭐⭐⭐"}
                      {review.stars && !review.stars.toString().includes("5") && !review.stars.toString().includes("4") && !review.stars.toString().includes("3") && review.stars}
                    </div>
                    <p class="content review-content-text">"{review.content}"</p>
                  </div>
                  
                  <div class="author-row notranslate">
                    <div class="flex flex-col">
                      <span class="author-name">{review.author_name || "Verified Guest"}</span>
                      {review.date && (
                        <span class="text-[11px] text-gray-400 mt-0.5 font-sans">
                          {new Date(review.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                        </span>
                      )}
                    </div>
                    <div class="platform-logo-wrapper">
                      {review.platform === "Google Review" && (
                        <div class="flex items-center gap-1 text-xs text-gray-500 font-semibold">
                          <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/></svg>
                          <span>Google</span>
                        </div>
                      )}
                      {review.platform === "Booking.com" && (
                        <span class="bg-blue-900 text-white font-extrabold px-1.5 py-0.5 rounded text-[10px] tracking-tight">Booking.com</span>
                      )}
                      {review.platform === "Traveloka" && (
                        <div class="flex items-center gap-1 text-[11px] font-bold text-sky-500 italic">
                          <svg class="w-4 h-4 text-sky-500 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19(5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                          <span>traveloka</span>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          {/* TRACK LANE 2 */}
          {isSlider && (
            <div class="marquee-group" aria-hidden="true">
              {
                sortedReviews.map((review) => (
                  <div class="review-card">
                    <div>
                      <div class="stars notranslate">
                        {review.stars && review.stars.toString().includes("5") && "⭐⭐⭐⭐⭐"}
                        {review.stars && review.stars.toString().includes("4") && "⭐⭐⭐⭐"}
                        {review.stars && review.stars.toString().includes("3") && "⭐⭐⭐"}
                        {review.stars && !review.stars.toString().includes("5") && !review.stars.toString().includes("4") && !review.stars.toString().includes("3") && review.stars}
                      </div>
                      <p class="content review-content-text">"{review.content}"</p>
                    </div>
                    
                    <div class="author-row notranslate">
                      <div class="flex flex-col">
                        <span class="author-name">{review.author_name || "Verified Guest"}</span>
                        {review.date && (
                          <span class="text-[11px] text-gray-400 mt-0.5 font-sans">
                            {new Date(review.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                          </span>
                        )}
                      </div>
                      <div class="platform-logo-wrapper">
                        {review.platform === "Google Review" && (
                          <div class="flex items-center gap-1 text-xs text-gray-500 font-semibold">
                            <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92(3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/></svg>
                            <span>Google</span>
                          </div>
                        )}
                        {review.platform === "Booking.com" && (
                          <span class="bg-blue-900 text-white font-extrabold px-1.5 py-0.5 rounded text-[10px] tracking-tight">Booking.com</span>
                        )}
                        {review.platform === "Traveloka" && (
                          <div class="flex items-center gap-1 text-[11px] font-bold text-sky-500 italic">
                            <svg class="w-4 h-4 text-sky-500 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19(5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                            <span>traveloka</span>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          )}

        </div>
      </div>
    </section>

    {/* Active Editorial Content Cards */}
    <Stories /> 

    {/* Past Archived Event Expansions */}
    <Archive />

    {/* Gallery Section: The Mutiara Experience Grid */}
    <section class="gallery-preview-section my-20 px-6 max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-10">
        <h2 class="
