---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";

import Rooms from "../components/rooms.astro";
import Stories from "../components/stories.astro"; 
import reviewsData from "../content/reviews.json";

// FETCH FLAT GALLERY PAYLOAD FOR THE HOMEPAGE TEASER GRID
import galleryData from "../content/gallery.json";
const homeGalleryTeasers = (galleryData || []).slice(0, 3);

const sortedReviews = (reviewsData || []).sort((a, b) => {
  return new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime();
});

const isSlider = sortedReviews.length > 4;
---

<Layout title="Mutiara Hotel & Convention">
  
  <div id="universal-translation-root">
    
    <Hero />

    <Features />

    <Stories /> 

    <Container>
      <Logos />
      <Cta />
    </Container>

    <section class="gallery-preview-section my-20 px-6 max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-10">
        <h2 class="text-3xl font-serif font-bold text-gray-800 mb-2">Our Gallery & Collections</h2>
        <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-4"></div>
        <p class="text-sm text-gray-500 font-sans">
          A sneak peek at our rare antique artifacts, boutique spaces, and fine colonial heritage preserved throughout the resort premises.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {homeGalleryTeasers.map((item) => (
          <div class="group relative aspect-[4/3] rounded-xl overflow-hidden bg-gray-100 border border-gray-200/60 shadow-sm">
            <img 
              src={item.image} 
              alt={item.title} 
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 block"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-slate-950/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-5 flex items-end">
              <div>
                <span class="text-[9px] font-sans font-bold text-amber-400 tracking-widest uppercase block mb-1 notranslate">{item.category}</span>
                <h4 class="text-white font-serif font-bold text-sm leading-tight">{item.title}</h4>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a 
          href="/gallery" 
          class="inline-flex items-center justify-center bg-gray-900 hover:bg-amber-600 text-white font-sans font-bold text-xs tracking-wider uppercase px-7 py-3 rounded-full shadow-md transition-all duration-300"
        >
          Explore Full Gallery &rarr;
        </a>
      </div>
    </section>

    <section class="reviews-section my-16 px-6 max-w-7xl mx-auto overflow-hidden">
      <h2 class="text-center text-3xl font-bold mb-2 text-gray-800">What Our Guests Love About Us</h2>
      <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-10"></div>
      
      <div class="marquee-viewport">
        <div class={`marquee-track ${isSlider ? 'animate-marquee' : 'justify-center'}`}>
          
          <div class="marquee-group">
            {
              sortedReviews.map((review) => (
                <div class="review-card">
                  <div>
                    <div class="stars notranslate">
                      {review.stars && review.stars.toString().includes("5") && "⭐⭐⭐⭐⭐"}
                      {review.stars && review.stars.toString().includes("4") && "⭐⭐⭐⭐"}
                      {review.stars && review.stars.toString().includes("3") && "⭐⭐⭐"}
                      {review.stars && !review.stars.toString().includes("5") && !review.stars.toString().includes("4") && !review.stars.toString().includes("3") && review.stars}
                    </div>
                    <p class="content review-content-text">"{review.content}"</p>
                  </div>
                  
                  <div class="author-row notranslate">
                    <div class="flex flex-col">
                      <span class="author-name">{review.author_name || "Verified Guest"}</span>
                      {review.date && (
                        <span class="text-[11px] text-gray-400 mt-0.5 font-sans">
                          {new Date(review.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                        </span>
                      )}
                    </div>
                    <div class="platform-logo-wrapper">
                      {review.platform === "Google Review" && (
                        <div class="flex items-center gap-1 text-xs text-gray-500 font-semibold">
                          <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/></svg>
                          <span>Google</span>
                        </div>
                      )}
                      {review.platform === "Booking.com" && (
                        <span class="bg-blue-900 text-white font-extrabold px-1.5 py-0.5 rounded text-[10px] tracking-tight">Booking.com</span>
                      )}
                      {review.platform === "Traveloka" && (
                        <div class="flex items-center gap-1 text-[11px] font-bold text-sky-500 italic">
                          <svg class="w-4 h-4 text-sky-500 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19(5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                          <span>traveloka</span>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          {/* TRACK LANE 2 */}
          {isSlider && (
            <div class="marquee-group" aria-hidden="true">
              {
                sortedReviews.map((review) => (
                  <div class="review-card">
                    <div>
                      <div class="stars notranslate">
                        {review.stars && review.stars.toString().includes("5") && "⭐⭐⭐⭐⭐"}
                        {review.stars && review.stars.toString().includes("4") && "⭐⭐⭐⭐"}
                        {review.stars && review.stars.toString().includes("3") && "⭐⭐⭐"}
                        {review.stars && !review.stars.toString().includes("5") && !review.stars.toString().includes("4") && !review.stars.toString().includes("3") && review.stars}
                      </div>
                      <p class="content review-content-text">"{review.content}"</p>
                    </div>
                    
                    <div class="author-row notranslate">
                      <div class="flex flex-col">
                        <span class="author-name">{review.author_name || "Verified Guest"}</span>
                        {review.date && (
                          <span class="text-[11px] text-gray-400 mt-0.5 font-sans">
                            {new Date(review.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                          </span>
                        )}
                      </div>
                      <div class="platform-logo-wrapper">
                        {review.platform === "Google Review" && (
                          <div class="flex items-center gap-1 text-xs text-gray-500 font-semibold">
                            <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/></svg>
                            <span>Google</span>
                          </div>
                        )}
                        {review.platform === "Booking.com" && (
                          <span class="bg-blue-900 text-white font-extrabold px-1.5 py-0.5 rounded text-[10px] tracking-tight">Booking.com</span>
                        )}
                        {review.platform === "Traveloka" && (
                          <div class="flex items-center gap-1 text-[11px] font-bold text-sky-500 italic">
                            <svg class="w-4 h-4 text-sky-500 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19(5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                            <span>traveloka</span>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          )}

        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .reviews-section { padding: 40px 0; }
  .marquee-viewport { width: 100%; overflow: hidden; position: relative; padding: 14px 0; }
  .marquee-track { display: flex; flex-direction: row; width: max-content; }
  .marquee-group { display: flex; flex-direction: row; gap: 24px; padding: 0 12px; shrink: 0; }
  .animate-marquee { animation: marqueeAnimation 25s linear infinite; }
  .animate-marquee:hover { animation-play-state: paused; }
  @keyframes marqueeAnimation {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
  .marquee-track:not(.animate-marquee) { width: 100%; max-width: 1200px; margin: 0 auto; justify-content: center; }
  @media (max-width: 1024px) {
    .marquee-viewport { overflow-x: auto; scrollbar-width: none; }
    .marquee-viewport::-webkit-scrollbar { display: none; }
    .marquee-track:not(.animate-marquee) { width: max-content; justify-content: flex-start; margin: 0; }
  }
  .review-card {
    background: white; padding: 24px; border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    border: 1px solid #e5e7eb; width: 275px; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box;
  }
  .stars { color: #fbbf24; margin-bottom: 12px; font-size: 16px; }
  .review-card .content { color: #4b5563; font-style: italic; font-size: 14px; line-height: 1.6; margin-bottom: 20px; }
  .author-row { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid #f3f4f6; padding-top: 14px; }
  .author-name { color: #1f2937; font-size: 13px; font-weight: 500; }
</style>
