---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";

// Import your dynamic guest reviews database list
import reviewsData from "@/content/reviews.json";
---

<Layout title="Mutiara Hotel & Convention">
  
  <Hero />

  <Container>
    <Features />
    <Logos />
    <Cta />
  </Container>

  <section class="reviews-section my-16">
    <h2 class="text-center text-3xl font-bold mb-6 text-gray-800">What Our Guests Love About Us</h2>
    
    <div class="marquee-container">
      <div class="marquee-track">
        {
          reviewsData.map((review) => (
            <div class="review-card">
              <div class="stars">
                {review.stars === "5" && "⭐⭐⭐⭐⭐"}
                {review.stars === "4" && "⭐⭐⭐⭐"}
                {review.stars === "3" && "⭐⭐⭐"}
                {/* Fallback support for older text entries if any exist */}
                {!["5", "4", "3"].includes(review.stars) && review.stars}
              </div>
              <p class="content">"{review.content}"</p>
              <p class="author">
                {review.author_name ? `${review.author_name}, ` : ""}
                <span class="text-emerald-800 font-semibold">{review.platform || "Google Review"}</span>
              </p>
            </div>
          ))
        }
        {/* Duplicate rendering loop block ensures an endless, smooth infinite marquee loop layout */}
        {
          reviewsData.map((review) => (
            <div class="review-card" aria-hidden="true">
              <div class="stars">
                {review.stars === "5" && "⭐⭐⭐⭐⭐"}
                {review.stars === "4" && "⭐⭐⭐⭐"}
                {review.stars === "3" && "⭐⭐⭐"}
                {!["5", "4", "3"].includes(review.stars) && review.stars}
              </div>
              <p class="content">"{review.content}"</p>
              <p class="author">
                {review.author_name ? `${review.author_name}, ` : ""}
                <span class="text-emerald-800 font-semibold">{review.platform || "Google Review"}</span>
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
  
  <style>
  .reviews-section {
    padding: 40px 0;
    background-color: #f9fafb;
    overflow: hidden;
  }
  .marquee-container {
    width: 100%;
    overflow: hidden;
    padding: 10px 0;
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: scrollMarquee 30s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  .review-card {
    width: 350px;
    background: white;
    margin: 0 15px;
    padding: 24px;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 1px solid #e5e7eb;
  }
  .stars {
    color: #fbbf24;
    margin-bottom: 8px;
  }
  .review-card .content {
    color: #4b5563;
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .review-card .author {
    color: #1f2937;
    font-weight: normal;
    font-size: 14px;
  }
  
  @keyframes scrollMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
</Layout>
