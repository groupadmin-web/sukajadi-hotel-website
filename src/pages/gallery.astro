---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

// Flat database import pattern matching your other pages exactly
import galleryData from "../content/gallery.json";

// Safe array fallback to prevent build crashes if the file is being edited
const artifacts = galleryData || [];
---

<Layout title="Art Gallery & Heritage Collections">
  {/* THE MASTER TRANSLATION ROOT REQUIRED BY YOUR PIPELINE LAYER */}
  <div id="universal-translation-root">
    <Container>
      
      {/* HEADER SECTION */}
      <div class="text-center max-w-2xl mx-auto my-16">
        <h1 class="text-4xl font-serif font-bold text-gray-800 mb-3">Our Art Gallery & Collections</h1>
        <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-5"></div>
        <p class="text-sm text-gray-500 font-sans leading-relaxed">
          Explore the visual narrative of Mutiara Hotel. A curated collection of museum-grade antique artifacts, ancient crafts, and traditional decor pieces preserved throughout the premises.
        </p>
      </div>

      {/* CLEAN, LIGHTWEIGHT RESPONSIVE GRID (No broken filter buttons!) */}
      <div id="master-gallery-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
        {artifacts.map((item) => (
          <div class="gallery-card bg-white rounded-2xl overflow-hidden border border-gray-200/60 shadow-sm flex flex-col justify-between">
            
            {/* IMAGE FRAME */}
            <div class="relative aspect-[4/3] w-full overflow-hidden bg-gray-100">
              <img 
                src={item.image} 
                alt={item.title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105 block"
              />
            </div>

            {/* ART DETAILS INFORMATION */}
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="text-xl font-serif font-bold text-gray-800 mb-2 leading-tight">
                  {item.title}
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed font-sans font-normal">
                  {item.description}
                </p>
              </div>
            </div>

          </div>
        ))}
      </div>

    </Container>
  </div>
  <BookingToast />
</Layout>
