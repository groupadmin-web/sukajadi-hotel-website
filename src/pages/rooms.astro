---
// src/pages/rooms.astro
import Layout from "../layouts/Layout.astro";
import roomsData from "../content/rooms.json";

const rooms = Array.isArray(roomsData) ? roomsData : [];
---

<Layout title="Rooms & Suites | Mutiara Hotel & Convention">
  <style is:global>
    body:has(.gallery-modal[data-open="true"]) {
      overflow: hidden !important;
    }
  </style>

  <div class="bg-gray-50 min-h-screen py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center mb-16 mt-8">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-gray-900 tracking-wide uppercase mb-4">Our Rooms & Suites</h1>
      <div class="w-24 h-1 bg-amber-600 mx-auto mb-6"></div>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rooms.map((room, index) => {
        // BULLETPROOF PARSER: Safely reads arrays or strings so your build never breaks
        const amenityArray = Array.isArray(room.features)
          ? room.features.map(item => String(item).trim()).filter(Boolean)
          : typeof room.features === 'string'
            ? room.features.split(',').map(item => item.trim()).filter(Boolean)
            : [];

        return (
          <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100 flex flex-col justify-between">
            <div class="relative h-64 bg-gray-200 overflow-hidden">
              <img src={room.image || "/images/slide-1.jpg"} alt={room.title} class="w-full h-full object-cover" />
              <div class="absolute top-4 right-4 bg-gray-900/80 text-white text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-md font-sans">
                {room.view || "Standard View"}
              </div>
            </div>

            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <h2 class="text-2xl font-serif font-bold text-gray-800 mb-3 uppercase tracking-wide">{room.title}</h2>
                <p class="text-gray-500 text-sm font-sans mb-6 font-light leading-relaxed line-clamp-3">{room.description}</p>
              </div>

              <div class="border-t border-b border-gray-100 py-4 my-2 grid grid-cols-2 gap-2 text-[11px] uppercase font-sans tracking-wider text-gray-500">
                <div class="flex items-center gap-2"><span>🛏️</span><span>{room.bed_type}</span></div>
                <div class="flex items-center gap-2"><span>👤</span><span>MAX {room.capacity}</span></div>
              </div>
            </div>

            <div class="px-6 pb-6 pt-2">
              <div class="flex flex-wrap gap-1.5 mb-6 min-h-[52px]">
                {amenityArray.slice(0, 3).map((feature) => (
                  <span class="bg-amber-50/70 text-amber-800 text-[10px] tracking-wider uppercase px-2.5 py-1.5 rounded-md font-semibold font-sans whitespace-nowrap">
                    {feature}
                  </span>
                ))}
              </div>
              <button type="button" data-open-modal={index} class="block w-full bg-amber-600 hover:bg-amber-700 text-white text-center font-bold text-sm py-3.5 rounded-lg tracking-wider uppercase cursor-pointer shadow-md">
                View Gallery
              </button>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  {rooms.map((room, index) => {
    const modalAmenityArray = Array.isArray(room.features)
      ? room.features.map(item => String(item).trim()).filter(Boolean)
      : typeof room.features === 'string'
        ? room.features.split(',').map(item => item.trim()).filter(Boolean)
        : [];

    return (
      <div id={`gallery-modal-${index}`} class="gallery-modal fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[99999] hidden items-center justify-center p-4" data-open="false">
        <div class="bg-white rounded-2xl max-w-5xl w-full shadow-2xl overflow-hidden flex flex-col md:flex-row relative max-h-[85vh]">
          <button type="button" data-close-modal={index} class="absolute top-4 right-4 z-[100100] bg-white text-gray-700 border border-gray-200 rounded-full w-10 h-10 flex items-center justify-center font-bold shadow-md cursor-pointer">✕</button>
          
          <div class="md:w-7/12 bg-slate-900 relative min-h-[250px]">
            <img id={`modal-display-img-${index}`} src={room.image} class="w-full h-full object-cover absolute inset-0" alt="" />
            <div class="absolute bottom-4 left-4 bg-slate-950/70 text-white text-xs tracking-widest px-3 py-1.5 rounded-md uppercase">{room.view}</div>
          </div>

          <div class="md:w-5/12 p-6 md:p-8 flex flex-col justify-between overflow-y-auto bg-white">
            <div>
              <h3 class="text-2xl font-serif font-bold text-gray-900 mb-4 uppercase">{room.title}</h3>
              <p class="text-gray-600 text-sm font-light mb-6">{room.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {modalAmenityArray.map((feature) => (
                  <span class="bg-slate-100 text-slate-800 text-[10px] tracking-wide uppercase px-3 py-1.5 rounded border border-slate-200 whitespace-nowrap">
                    {feature}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  })}
</Layout>

<script is:inline>
  function initSplitGalleryPopups() {
    document.querySelectorAll('[data-open-modal]').forEach(btn => {
      btn.onclick = () => {
        const idx = btn.getAttribute('data-open-modal');
        const modal = document.getElementById(`gallery-modal-${idx}`);
        if (modal) {
          modal.setAttribute('data-open', 'true');
          modal.style.setProperty('display', 'flex', 'important');
        }
      };
    });
    document.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.onclick = () => {
        const idx = btn.getAttribute('data-close-modal');
        const modal = document.getElementById(`gallery-modal-${idx}`);
        if (modal) {
          modal.setAttribute('data-open', 'false');
          modal.style.setProperty('display', 'none', 'important');
        }
      };
    });
  }
  initSplitGalleryPopups();
  document.addEventListener('astro:after-swap', initSplitGalleryPopups);
</script>
