---
// src/pages/rooms.astro
import Layout from "../layouts/Layout.astro";
import roomsData from "../content/rooms.json";

// The script reads your room configurations straight from CloudCannon!
const rooms = Array.isArray(roomsData) ? roomsData : [];
---

<Layout title="Rooms & Suites | Mutiara Hotel & Convention">
  <div class="bg-gray-50 min-h-screen py-16 px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-4xl mx-auto text-center mb-16 mt-8">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-gray-900 tracking-wide uppercase mb-4">
        Our Rooms & Suites
      </h1>
      <div class="w-24 h-1 bg-amber-600 mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-light max-w-2xl mx-auto italic">
        "Experience ultimate comfort in our rooms blending modern luxury with classic colonial charm."
      </p>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rooms.map((room) => (
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100 transform hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between">
          
          <div class="relative h-64 bg-gray-200 overflow-hidden">
            <img 
              src={room.image || "/images/slide-1.jpg"} 
              alt={room.title} 
              class="w-full h-full object-cover"
            />
            <div class="absolute top-4 right-4 bg-gray-900/80 backdrop-blur-sm text-white text-xs tracking-widest uppercase px-3 py-1.5 rounded-md font-sans">
              {room.view || "City View"}
            </div>
          </div>

          <div class="p-6 flex-grow flex flex-col justify-between">
            <div>
              <h2 class="text-2xl font-serif font-bold text-gray-800 mb-3 uppercase tracking-wide">
                {room.title}
              </h2>
              <p class="text-gray-600 text-sm font-sans mb-6 font-light leading-relaxed line-clamp-3">
                {room.description}
              </p>
            </div>

            <div class="border-t border-b border-gray-100 py-3.5 my-4 grid grid-cols-2 gap-2 text-xs uppercase font-sans tracking-wider text-gray-500">
              <div class="flex items-center gap-2">
                <span class="text-amber-600 font-bold">🛏️</span> {room.bed_type || "King Bed"}
              </div>
              <div class="flex items-center gap-2">
                <span class="text-amber-600 font-bold">👤</span> Max {room.capacity || "2-4"} Guest
              </div>
            </div>
          </div>

          <div class="px-6 pb-6 pt-2">
            <div class="flex flex-wrap gap-1.5 mb-5">
              {room.features && room.features.slice(0, 3).map((feature) => (
                <span class="bg-amber-50 text-amber-800 text-[10px] tracking-wider uppercase px-2.5 py-1 rounded-md font-medium">
                  {feature}
                </span>
              ))}
            </div>

            <a 
              href="https://m.mutiarahotel.com" 
              class="block w-full bg-amber-600 hover:bg-amber-700 text-white text-center font-bold font-sans text-sm py-3 rounded-lg shadow transition-all tracking-wider uppercase"
            >
              Book Room
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</Layout>
