---
// src/pages/rooms.astro
import Layout from "../layouts/Layout.astro";
import roomsData from "../content/rooms.json";

const rooms = Array.isArray(roomsData) ? roomsData : [];
---

<Layout title="Rooms & Suites | Mutiara Hotel & Convention">
  <div class="bg-gray-50 min-h-screen py-16 px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-4xl mx-auto text-center mb-16 mt-8">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-gray-900 tracking-wide uppercase mb-4">
        Our Rooms & Suites
      </h1>
      <div class="w-24 h-1 bg-amber-600 mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-light max-w-2xl mx-auto italic">
        "Experience ultimate comfort in our rooms blending modern luxury with classic colonial charm."
      </p>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rooms.map((room, index) => (
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1 transition-all duration-300">
          
          <div class="relative h-64 bg-gray-200 overflow-hidden">
            <img 
              src={room.image || "/images/slide-1.jpg"} 
              alt={room.title} 
              class="w-full h-full object-cover"
            />
            <div class="absolute top-4 right-4 bg-gray-900/80 backdrop-blur-sm text-white text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-md font-sans font-medium">
              {room.view || "Standard View"}
            </div>
          </div>

          <div class="p-6 flex-grow flex flex-col justify-between">
            <div>
              <h2 class="text-2xl font-serif font-bold text-gray-800 mb-3 uppercase tracking-wide">
                {room.title}
              </h2>
              <p class="text-gray-500 text-sm font-sans mb-6 font-light leading-relaxed line-clamp-3">
                {room.description}
              </p>
            </div>

            <div class="border-t border-b border-gray-100 py-4 my-2 grid grid-cols-2 gap-2 text-[11px] uppercase font-sans tracking-wider text-gray-500 font-medium">
              <div class="flex items-center gap-2">
                <span class="text-slate-400 text-base">🛏️</span>
                <span>{room.bed_type || "Twin Beds"}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-slate-400 text-base">👤</span>
                <span>MAX {room.capacity || "2 PEOPLE"} GUEST</span>
              </div>
            </div>
          </div>

          <div class="px-6 pb-6 pt-2">
            <div class="flex flex-wrap gap-1.5 mb-6 min-h-[52px]">
              {room.features && room.features.slice(0, 3).map((feature) => (
                <span class="bg-amber-50/70 text-amber-800 text-[10px] tracking-wider uppercase px-2.5 py-1.5 rounded-md font-semibold font-sans">
                  {feature}
                </span>
              ))}
            </div>

            {/* THE GALLERY TRIGGER BUTTON */}
            <button 
              data-gallery-trigger={index}
              class="block w-full bg-amber-600 hover:bg-amber-700 text-white text-center font-bold font-sans text-sm py-3.5 rounded-lg shadow-md hover:shadow-lg transition-all tracking-wider uppercase cursor-pointer"
            >
              View Gallery
            </button>
          </div>

          {/* LIGHTBOX POPUP MODAL WITH HORIZONTAL ROW FLOW */}
          <div id={`gallery-modal-${index}`} class="fixed inset-0 bg-gray-950/80 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
            <div class="bg-white rounded-xl p-6 max-w-4xl w-full shadow-2xl relative">
              <button data-close-trigger={index} class="absolute -top-12 right-0 text-white hover:text-amber-500 text-sm uppercase font-bold tracking-widest cursor-pointer">✕ Close</button>
              <h3 class="text-xl font-serif font-bold text-gray-900 mb-6 uppercase tracking-wider">{room.title} Gallery Photo Showcase</h3>
              
              {/* HORIZONTAL FLEXBOX CONTAINER */}
              <div class="flex flex-row flex-wrap items-center justify-start gap-4 p-2 max-h-[60vh] overflow-y-auto">
                
                {/* Main Feature Cover */}
                <div class="w-40 sm:w-52 aspect-video bg-gray-100 rounded-lg overflow-hidden border border-gray-200 shadow-sm flex-shrink-0">
                  <img src={room.image} class="w-full h-full object-cover" alt="Main cover display photo"/>
                </div>
                
                {/* Additional Upload Slot 1 */}
                {room.room_gallery1 && (
                  <div class="w-40 sm:w-52 aspect-video bg-gray-100 rounded-lg overflow-hidden border border-gray-200 shadow-sm flex-shrink-0">
                    <img src={room.room_gallery1} class="w-full h-full object-cover hover:scale-105 transition-transform duration-200" alt="Room detail image 1"/>
                  </div>
                )}
                
                {/* Additional Upload Slot 2 */}
                {room.room_gallery2 && (
                  <div class="w-40 sm:w-52 aspect-video bg-gray-100 rounded-lg overflow-hidden border border-gray-200 shadow-sm flex-shrink-0">
                    <img src={room.room_gallery2} class="w-full h-full object-cover hover:scale-105 transition-transform duration-200" alt="Room detail image 2"/>
                  </div>
                )}
                
                {/* Additional Upload Slot 3 */}
                {room.room_gallery3 && (
                  <div class="w-40 sm:w-52 aspect-video bg-gray-100 rounded-lg overflow-hidden border border-gray-200 shadow-sm flex-shrink-0">
                    <img src={room.room_gallery3} class="w-full h-full object-cover hover:scale-105 transition-transform duration-200" alt="Room detail image 3"/>
                  </div>
                )}
                
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</Layout>

<script is:inline>
  function initGalleryPopups() {
    const openBtns = document.querySelectorAll('[data-gallery-trigger]');
    
    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-gallery-trigger');
        const
