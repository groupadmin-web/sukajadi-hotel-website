---
// src/pages/food.astro
import Layout from "../layouts/Layout.astro";
import BookingToast from "@/components/BookingToast.astro";

// 1. DEFAULT DATA BACKENDS FALL-SAFES
const defaultRestaurants = [
  {
    title: "The Grand Mutiara Pavilion",
    distance: "0.1 km (Inside Hotel)",
    image: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=800&q=80",
    tagline: "Premium Authentic Dining",
    cuisine: "Sundanese Fusion",
    website_url: "https://m.mutiarahotel.com/dining"
  },
  {
    title: "Kebon Kawung Culinary Street",
    distance: "0.2 Miles (4 Min Walk)",
    image: "https://images.unsplash.com/photo-1565557623262-b51c2513a641?auto=format&fit=crop&w=800&q=80",
    tagline: "Traditional Local Snacks",
    cuisine: "Local Snacks",
    website_url: ""
  },
  {
    title: "23 Paskal Food Market",
    distance: "0.4 Miles (8 Min Walk)",
    image: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=800&q=80",
    tagline: "Massive Culinary Variety Hub",
    cuisine: "Food Court",
    website_url: ""
  }
];

// 2. DYNAMIC DUAL-STRUCTURE CONTENT INGESTION ENGINE 
let rawCmsData = null;
try {
  const restaurantsData = await import("../content/restaurants.json");
  if (restaurantsData && restaurantsData.default) {
    rawCmsData = restaurantsData.default;
  }
} catch (e) {}

// Extract top-level descriptive headers
const dynamicPageDescription = rawCmsData?.page_description || "From traditional Sundanese family recipes right inside our venue complex to the legendary culinary street paths of Bandung.";
const dynamicBreakfastNotice = rawCmsData?.breakfast_notice || "Please note that while Mutiara Hotel does not offer a daily breakfast buffet service, our central location provides an exceptional gateway to dozens of iconic Bandung local food stalls and premium cafes just steps from your room.";

// 🟢 FIXED: Safely filter list rows whether they are nested inside an object or formatted as a root-level array
let cmsItems = [];
if (Array.isArray(rawCmsData)) {
  cmsItems = rawCmsData;
} else if (rawCmsData) {
  // Checks common CMS nesting configurations (e.g., .restaurants, .listings, or .list)
  cmsItems = rawCmsData.restaurants || rawCmsData.restaurant_listings || rawCmsData.listings || rawCmsData.list || [];
}

const restaurants = defaultRestaurants.map((defaultItem, idx) => {
  const cmsItem = cmsItems.find(item => item && (item.title === defaultItem.title || item.name === defaultItem.title)) || cmsItems[idx] || {};
  return {
    title: cmsItem.title || cmsItem.name || defaultItem.title,
    distance: cmsItem.distance || defaultItem.distance,
    tagline: cmsItem.tagline || defaultItem.tagline,
    cuisine: cmsItem.cuisine_type || cmsItem.cuisine || defaultItem.cuisine,
    image: (cmsItem.image && cmsItem.image.trim() !== "") ? cmsItem.image : defaultItem.image,
    website_url: cmsItem.website_url || defaultItem.website_url || ""
  };
});
---

<Layout title="Local Dining Guide | Mutiara Hotel & Convention">
  <div class="bg-gray-50 min-h-screen py-16 px-4 sm:px-6 lg:px-8">

    <div class="max-w-4xl mx-auto text-center mb-12 mt-8">
      <span class="text-amber-600 font-sans text-xs tracking-widest uppercase font-bold block mb-1">Culinary Experience</span>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-gray-900 tracking-wide uppercase mb-4">Bandung Dining & Food</h1>
      <div class="w-24 h-1 bg-amber-600 mx-auto mb-6"></div>
      
      <p class="text-lg text-gray-600 font-light max-w-2xl mx-auto italic leading-relaxed">
        "{dynamicPageDescription}"
      </p>
    </div>

    <div class="max-w-3xl mx-auto mb-16 bg-amber-500/5 border border-amber-500/20 rounded-xl p-5 flex items-start gap-3.5 shadow-sm">
      <span class="text-xl select-none leading-none mt-0.5 shrink-0">🍳</span>
      <div class="flex-1 text-left">
        <h4 class="text-slate-900 font-sans text-xs font-bold uppercase tracking-wider mb-1">Local Breakfast Advisory</h4>
        <p class="text-xs text-gray-500 font-sans leading-relaxed">
          {dynamicBreakfastNotice}
        </p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
      {restaurants.map((item) => {
        const encodedLocationName = encodeURIComponent(`${item.title}, Bandung, West Java, Indonesia`);
        const exactMapUrl = `https://www.google.com/maps/search/?api=1&query=${encodedLocationName}`;

        return (
          <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1 hover:shadow-xl transition-all duration-300 w-full group">
            
            <div class="relative h-48 overflow-hidden bg-gray-100 shrink-0 select-none">
              <img 
                src={item.image} 
                alt={item.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                loading="lazy" 
              />
              <div class="absolute top-4 left-4 bg-gray-900/80 backdrop-blur-sm text-white text-[9px] tracking-widest uppercase px-2.5 py-1 rounded font-sans font-semibold notranslate">
                {item.cuisine}
              </div>
              <div class="absolute bottom-4 left-4 bg-slate-950/80 backdrop-blur-sm text-white text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-md font-sans font-medium flex items-center gap-1.5 shadow-md">
                <span>📍</span> <span>{item.distance}</span>
              </div>
            </div>

            <div class="p-5 flex-1 flex flex-col justify-between">
              <div class="mb-4">
                <span class="text-amber-600 text-[10px] tracking-widest uppercase font-sans font-bold block mb-1">
                  {item.tagline}
                </span>
                <h2 class="text-lg font-serif font-bold text-gray-800 tracking-wide uppercase line-clamp-2">
                  {item.title}
                </h2>
                <div class="w-8 h-0.5 bg-gray-200 mt-2"></div>
              </div>

              <div class="flex items-center gap-2 pt-3 border-t border-gray-100/80 text-[10px] font-sans font-bold tracking-wider uppercase">
                <a 
                  href={exactMapUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex-1 bg-slate-50 hover:bg-slate-100 text-gray-700 border border-gray-200/60 rounded-lg py-2.5 text-center transition-all flex items-center justify-center gap-1.5"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-amber-600">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  <span>View Pin</span>
                </a>

                {item.website_url && (
                  <a 
                    href={item.website_url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="flex-1 bg-amber-500 hover:bg-amber-400 text-slate-950 rounded-lg py-2.5 text-center transition-all block whitespace-nowrap"
                  >
                    Website ↗
                  </a>
                )}
              </div>
            </div>

          </div>
        );
      })}
    </div>

  </div>
  <BookingToast />
</Layout>
