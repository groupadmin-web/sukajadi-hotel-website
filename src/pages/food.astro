---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

// Pure flat file data layout matching your setup perfectly
import restaurantData from "@/content/restaurants.json";
const restaurants = restaurantData || [];
---

<Layout title="Local Dining & Culinary Guide">
  <div id="universal-translation-root">
    <Container class="py-12">
      
      <div class="text-center max-w-3xl mx-auto my-12">
        <span class="text-xs font-sans font-bold tracking-widest text-amber-600 uppercase block mb-2">Culinary Experience</span>
        <h1 class="text-4xl font-serif font-bold text-gray-800 mb-3">Bandung Dining & Restaurants</h1>
        <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-5"></div>
        <p class="text-sm text-gray-500 font-sans leading-relaxed">
          Explore the rich culinary heritage surrounding Mutiara Hotel. From local authentic Sundanese flavors to global premium fusion kitchens, discover our curation of nearby dining spots.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-24 w-full">
        {restaurants.map((place) => (
          <div class="bg-white rounded-2xl border border-gray-200/60 shadow-sm overflow-hidden flex flex-col justify-between transition-all duration-300 hover:shadow-md w-full group">
            
            <div class="relative overflow-hidden aspect-[4/3] bg-slate-100 flex-shrink-0">
              <img 
                src={place.image} 
                alt={place.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                onerror="this.src='/images/placeholder-dining.jpg';"
              />
              <span class="absolute top-3 left-3 bg-slate-900/80 backdrop-blur-sm border border-white/10 text-white font-sans text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md select-none notranslate">
                {place.cuisine_type}
              </span>
            </div>

            <div class="p-5 flex-1 flex flex-col justify-between">
              <div>
                <h3 class="text-lg font-serif font-bold text-gray-800 mb-1 leading-snug line-clamp-2">
                  {place.name}
                </h3>
                <div class="flex items-center gap-1.5 text-xs text-gray-400 font-sans mt-2">
                  <span class="text-amber-500 text-sm">📍</span>
                  <span>{place.distance} from Hotel</span>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-gray-100">
                <div class="flex items-center gap-2 w-full">
                  <a 
                    href={place.map_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 bg-slate-50 hover:bg-slate-100 text-gray-700 border border-gray-200/50 rounded-lg py-2 text-center text-[10px] font-sans font-bold uppercase tracking-wider transition-all block whitespace-nowrap"
                  >
                    View Map →
                  </a>

                  {place.website_url && (
                    <a 
                      href={place.website_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 bg-amber-500 hover:bg-amber-400 text-slate-950 rounded-lg py-2 text-center text-[10px] font-sans font-bold uppercase tracking-wider transition-all block whitespace-nowrap"
                    >
                      Website ↗
                    </a>
                  )}
                </div>
              </div>
            </div>

          </div>
        ))}
      </div>

    </Container>
  </div>
</Layout>
